{
  "name": "mymind",
  "version": "0.1.0",
  "description": "A local-first desktop second brain built with React, TypeScript, Electron, and JSON storage.",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.node.json --watch\" \"wait-on http://localhost:5173 dist-electron/main.js && electron .\"",
    "build": "node scripts/clean-build.cjs && tsc --noEmit && tsc -p tsconfig.node.json && vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@blocknote/core": "^0.51.0",
    "@blocknote/mantine": "^0.51.0",
    "@blocknote/react": "^0.51.0",
    "lucide-react": "^1.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tldraw": "^5.0.1"
  },
  "overrides": {
    "@tiptap/core": "3.13.0",
    "@tiptap/extension-blockquote": "3.13.0",
    "@tiptap/extension-bold": "3.13.0",
    "@tiptap/extension-bubble-menu": "3.13.0",
    "@tiptap/extension-bullet-list": "3.13.0",
    "@tiptap/extension-code": "3.13.0",
    "@tiptap/extension-code-block": "3.13.0",
    "@tiptap/extension-document": "3.13.0",
    "@tiptap/extension-dropcursor": "3.13.0",
    "@tiptap/extension-floating-menu": "3.13.0",
    "@tiptap/extension-gapcursor": "3.13.0",
    "@tiptap/extension-hard-break": "3.13.0",
    "@tiptap/extension-heading": "3.13.0",
    "@tiptap/extension-highlight": "3.13.0",
    "@tiptap/extension-horizontal-rule": "3.13.0",
    "@tiptap/extension-italic": "3.13.0",
    "@tiptap/extension-link": "3.13.0",
    "@tiptap/extension-list": "3.13.0",
    "@tiptap/extension-list-item": "3.13.0",
    "@tiptap/extension-ordered-list": "3.13.0",
    "@tiptap/extension-paragraph": "3.13.0",
    "@tiptap/extension-strike": "3.13.0",
    "@tiptap/extension-task-item": "3.13.0",
    "@tiptap/extension-task-list": "3.13.0",
    "@tiptap/extension-text": "3.13.0",
    "@tiptap/extension-underline": "3.13.0",
    "@tiptap/extensions": "3.13.0",
    "@tiptap/pm": "3.13.0",
    "@tiptap/react": "3.13.0",
    "@tiptap/starter-kit": "3.13.0",
    "prosemirror-model": "1.25.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
