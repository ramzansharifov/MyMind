{
    "name":  "mymind",
    "version":  "0.1.0",
    "description":  "A local-first desktop second brain built with React, TypeScript, Electron, and SQLite storage.",
    "main":  "dist-electron/main.js",
    "private":  true,
    "scripts":  {
                    "dev":  "concurrently -k \"vite\" \"tsc -p tsconfig.node.json --watch\" \"wait-on http://localhost:5173 dist-electron/main.js \u0026\u0026 electron .\"",
                    "build":  "node scripts/clean-build.cjs \u0026\u0026 tsc --noEmit \u0026\u0026 tsc -p tsconfig.node.json \u0026\u0026 vite build",
                    "test":  "node scripts/verify-notes-architecture.cjs \u0026\u0026 node scripts/verify-storage-sqlite.cjs",
                    "postinstall":  "electron-builder install-app-deps",
                    "rebuild:electron":  "electron-builder install-app-deps",
                    "start":  "electron .",
                    "dist":  "npm run build \u0026\u0026 electron-builder",
                    "dist:win":  "npm run build \u0026\u0026 electron-builder --win",
                    "rebuild:native":  "electron-rebuild -f -w better-sqlite3"
                },
    "dependencies":  {
                         "better-sqlite3":  "^11.10.0",
                         "highlight.js":  "^11.11.1",
                         "katex":  "^0.17.0",
                         "lucide-react":  "^1.14.0",
                         "react":  "^19.0.0",
                         "react-dom":  "^19.0.0",
                         "react-markdown":  "^10.1.0",
                         "recharts":  "^3.8.1",
                         "remark-gfm":  "^4.0.1"
                     },
    "devDependencies":  {
                            "@electron/rebuild":  "^4.0.4",
                            "@types/better-sqlite3":  "^7.6.13",
                            "@types/katex":  "^0.16.8",
                            "@types/node":  "^25.6.0",
                            "@types/react":  "^19.2.14",
                            "@types/react-dom":  "^19.2.3",
                            "@vitejs/plugin-react":  "^4.3.4",
                            "autoprefixer":  "^10.5.0",
                            "concurrently":  "^9.1.2",
                            "electron":  "^33.2.1",
                            "electron-builder":  "^25.1.8",
                            "postcss":  "^8.5.15",
                            "tailwindcss":  "^3.4.17",
                            "typescript":  "^5.7.2",
                            "vite":  "^6.0.7",
                            "wait-on":  "^8.0.1"
                        }
}