import { useMemo, useState } from "react";
import type {
  StudyNode,
  TableStudyBlock,
} from "../../types/study";
import {
  RichTextEditor,
  type RichTextActiveMarks,
  type RichTextCommand,
} from "./RichTextEditor";

interface FlexibleTableBlockProps {
  block: TableStudyBlock;
  nodes: StudyNode[];
  editable: boolean;
  formatCommand?: RichTextCommand | null;
  onChange: (block: TableStudyBlock) => void;
  onOpenNode: (nodeId: string) => void;
  onRichTextMarksChange?: (marks: RichTextActiveMarks) => void;
  onActiveRichTextEditorChange?: (editorId: string) => void;
}

interface SelectedCell {
  rowIndex: number;
  columnIndex: number;
}

const DEFAULT_COLUMN_WIDTH = 180;
const MIN_COLUMN_WIDTH = 80;
const MAX_COLUMN_WIDTH = 600;

function normalizeRows(rows: string[][]): string[][] {
  const safeRows = rows.length > 0 ? rows : [["", ""], ["", ""]];
  const maxColumns = Math.max(1, ...safeRows.map((row) => row.length));

  return safeRows.map((row) => [
    ...row,
    ...Array.from({ length: maxColumns - row.length }, () => ""),
  ]);
}

function normalizeColumnWidths(
  columnWidths: number[] | undefined,
  columnCount: number
): number[] {
  return Array.from({ length: columnCount }, (_, index) => {
    const width = columnWidths?.[index] ?? DEFAULT_COLUMN_WIDTH;

    return Math.max(MIN_COLUMN_WIDTH, Math.min(MAX_COLUMN_WIDTH, width));
  });
}

function stripHtml(value: string): string {
  if (!value) {
    return "";
  }

  const element = document.createElement("div");
  element.innerHTML = value;

  return element.textContent || element.innerText || "";
}

function escapeCsvCell(value: string): string {
  const cleanValue = stripHtml(value);

  if (
    cleanValue.includes(",") ||
    cleanValue.includes('"') ||
    cleanValue.includes("\n")
  ) {
    return `"${cleanValue.replaceAll('"', '""')}"`;
  }

  return cleanValue;
}

function downloadTextFile(fileName: string, content: string, mimeType: string) {
  const blob = new Blob([content], {
    type: mimeType,
  });

  const url = URL.createObjectURL(blob);
  const link = document.createElement("a");

  link.href = url;
  link.download = fileName;
  link.click();

  URL.revokeObjectURL(url);
}

export function FlexibleTableBlock({
  block,
  nodes,
  editable,
  formatCommand,
  onChange,
  onOpenNode,
  onRichTextMarksChange,
  onActiveRichTextEditorChange,
}: FlexibleTableBlockProps) {
  const [selectedCell, setSelectedCell] = useState<SelectedCell | null>(null);

  const rows = useMemo(() => normalizeRows(block.rows), [block.rows]);
  const columnCount = Math.max(1, rows[0]?.length ?? 1);
  const columnWidths = useMemo(
    () => normalizeColumnWidths(block.columnWidths, columnCount),
    [block.columnWidths, columnCount]
  );

  const activeRowIndex = selectedCell?.rowIndex ?? null;
  const activeColumnIndex = selectedCell?.columnIndex ?? null;
  const hasSelectedCell = activeRowIndex !== null && activeColumnIndex !== null;

  function getCellEditorId(rowIndex: number, columnIndex: number): string {
    return `${block.id}:cell:${rowIndex}:${columnIndex}`;
  }

  function updateBlock(nextRows: string[][], nextColumnWidths = columnWidths) {
    onChange({
      ...block,
      rows: nextRows,
      columnWidths: nextColumnWidths,
    });
  }

  function updateCell(rowIndex: number, columnIndex: number, value: string) {
    const nextRows = rows.map((row, currentRowIndex) =>
      currentRowIndex === rowIndex
        ? row.map((cell, currentColumnIndex) =>
            currentColumnIndex === columnIndex ? value : cell
          )
        : row
    );

    updateBlock(nextRows);
  }

  function addRowAt(index: number) {
    const safeIndex = Math.max(0, Math.min(rows.length, index));
    const emptyRow = Array.from({ length: columnCount }, () => "");

    updateBlock([
      ...rows.slice(0, safeIndex),
      emptyRow,
      ...rows.slice(safeIndex),
    ]);

    setSelectedCell({
      rowIndex: safeIndex,
      columnIndex: selectedCell?.columnIndex ?? 0,
    });
  }

  function addColumnAt(index: number) {
    const safeIndex = Math.max(0, Math.min(columnCount, index));

    const nextRows = rows.map((row) => [
      ...row.slice(0, safeIndex),
      "",
      ...row.slice(safeIndex),
    ]);

    const nextColumnWidths = [
      ...columnWidths.slice(0, safeIndex),
      DEFAULT_COLUMN_WIDTH,
      ...columnWidths.slice(safeIndex),
    ];

    updateBlock(nextRows, nextColumnWidths);

    setSelectedCell({
      rowIndex: selectedCell?.rowIndex ?? 0,
      columnIndex: safeIndex,
    });
  }

  function removeRow(rowIndex: number) {
    if (rows.length <= 1) {
      return;
    }

    const nextRows = rows.filter((_, index) => index !== rowIndex);

    updateBlock(nextRows);

    setSelectedCell({
      rowIndex: Math.max(0, Math.min(rowIndex, nextRows.length - 1)),
      columnIndex: selectedCell?.columnIndex ?? 0,
    });
  }

  function removeColumn(columnIndex: number) {
    if (columnCount <= 1) {
      return;
    }

    const nextRows = rows.map((row) => row.filter((_, index) => index !== columnIndex));
    const nextColumnWidths = columnWidths.filter((_, index) => index !== columnIndex);

    updateBlock(nextRows, nextColumnWidths);

    setSelectedCell({
      rowIndex: selectedCell?.rowIndex ?? 0,
      columnIndex: Math.max(0, Math.min(columnIndex, nextColumnWidths.length - 1)),
    });
  }

  function moveRow(rowIndex: number, direction: -1 | 1) {
    const targetIndex = rowIndex + direction;

    if (targetIndex < 0 || targetIndex >= rows.length) {
      return;
    }

    const nextRows = [...rows];
    const current = nextRows[rowIndex];

    nextRows[rowIndex] = nextRows[targetIndex];
    nextRows[targetIndex] = current;

    updateBlock(nextRows);

    setSelectedCell({
      rowIndex: targetIndex,
      columnIndex: selectedCell?.columnIndex ?? 0,
    });
  }

  function setColumnWidth(columnIndex: number, width: number) {
    const safeWidth = Math.max(MIN_COLUMN_WIDTH, Math.min(MAX_COLUMN_WIDTH, width));

    const nextColumnWidths = columnWidths.map((currentWidth, index) =>
      index === columnIndex ? safeWidth : currentWidth
    );

    updateBlock(rows, nextColumnWidths);
  }

  function exportCsv() {
    const csv = rows
      .map((row) => row.map(escapeCsvCell).join(","))
      .join("\n");

    downloadTextFile("table.csv", csv, "text/csv;charset=utf-8");
  }

  return (
    <div className="border border-black bg-white">
      {editable && (
        <div className="space-y-3 border-b border-black bg-neutral-100 p-3">
          <div className="flex flex-wrap gap-2">
            <button
              type="button"
              onClick={() => addRowAt(rows.length)}
              className="border border-black bg-white px-3 py-1 text-sm hover:bg-black hover:text-white"
            >
              + Row end
            </button>

            <button
              type="button"
              onClick={() => addColumnAt(columnCount)}
              className="border border-black bg-white px-3 py-1 text-sm hover:bg-black hover:text-white"
            >
              + Column end
            </button>

            <button
              type="button"
              onClick={exportCsv}
              className="border border-black bg-white px-3 py-1 text-sm hover:bg-black hover:text-white"
            >
              Export CSV
            </button>

            <label className="flex items-center gap-2 border border-black bg-white px-3 py-1 text-sm">
              <input
                type="checkbox"
                checked={block.hasHeader}
                onChange={(event) =>
                  onChange({
                    ...block,
                    rows,
                    columnWidths,
                    hasHeader: event.target.checked,
                  })
                }
              />
              Header
            </label>
          </div>

          <div className="border border-black bg-white p-2">
            <div className="mb-2 text-xs text-neutral-600">
              {hasSelectedCell
                ? `Активная ячейка: строка ${activeRowIndex! + 1}, колонка ${activeColumnIndex! + 1}`
                : "Кликни по ячейке, чтобы включить действия рядом с ней."}
            </div>

            <div className="flex flex-wrap gap-2">
              <button
                type="button"
                disabled={!hasSelectedCell}
                onClick={() => addRowAt(activeRowIndex!)}
                className="border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400"
              >
                Row above
              </button>

              <button
                type="button"
                disabled={!hasSelectedCell}
                onClick={() => addRowAt(activeRowIndex! + 1)}
                className="border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400"
              >
                Row below
              </button>

              <button
                type="button"
                disabled={!hasSelectedCell || rows.length <= 1}
                onClick={() => removeRow(activeRowIndex!)}
                className="border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400"
              >
                Delete row
              </button>

              <button
                type="button"
                disabled={!hasSelectedCell}
                onClick={() => addColumnAt(activeColumnIndex!)}
                className="border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400"
              >
                Column left
              </button>

              <button
                type="button"
                disabled={!hasSelectedCell}
                onClick={() => addColumnAt(activeColumnIndex! + 1)}
                className="border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400"
              >
                Column right
              </button>

              <button
                type="button"
                disabled={!hasSelectedCell || columnCount <= 1}
                onClick={() => removeColumn(activeColumnIndex!)}
                className="border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400"
              >
                Delete column
              </button>

              <button
                type="button"
                disabled={!hasSelectedCell}
                onClick={() => moveRow(activeRowIndex!, -1)}
                className="border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400"
              >
                Row up
              </button>

              <button
                type="button"
                disabled={!hasSelectedCell}
                onClick={() => moveRow(activeRowIndex!, 1)}
                className="border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400"
              >
                Row down
              </button>
            </div>

            {hasSelectedCell && (
              <label className="mt-3 flex flex-wrap items-center gap-2 border-t border-black pt-3 text-sm">
                <span className="font-bold">
                  Width column {activeColumnIndex! + 1}
                </span>

                <input
                  type="range"
                  min={MIN_COLUMN_WIDTH}
                  max={MAX_COLUMN_WIDTH}
                  value={columnWidths[activeColumnIndex!]}
                  onChange={(event) =>
                    setColumnWidth(activeColumnIndex!, Number(event.target.value))
                  }
                  className="min-w-[180px] flex-1"
                />

                <input
                  type="number"
                  min={MIN_COLUMN_WIDTH}
                  max={MAX_COLUMN_WIDTH}
                  value={columnWidths[activeColumnIndex!]}
                  onChange={(event) =>
                    setColumnWidth(activeColumnIndex!, Number(event.target.value))
                  }
                  className="w-24 border border-black bg-white px-2 py-1 outline-none"
                />

                <span>px</span>
              </label>
            )}
          </div>
        </div>
      )}

      <div className="overflow-auto">
        <table className="border-collapse text-sm">
          <colgroup>
            {Array.from({ length: columnCount }, (_, columnIndex) => (
              <col
                key={columnIndex}
                style={{
                  width: columnWidths[columnIndex],
                  minWidth: columnWidths[columnIndex],
                }}
              />
            ))}
          </colgroup>

          <tbody>
            {rows.map((row, rowIndex) => {
              const isHeader = block.hasHeader && rowIndex === 0;

              return (
                <tr key={rowIndex} className={isHeader ? "bg-neutral-100 font-bold" : ""}>
                  {row.map((cell, columnIndex) => {
                    const CellTag = isHeader ? "th" : "td";
                    const isSelected =
                      selectedCell?.rowIndex === rowIndex &&
                      selectedCell?.columnIndex === columnIndex;

                    return (
                      <CellTag
                        key={columnIndex}
                        onMouseDown={() => {
                          setSelectedCell({
                            rowIndex,
                            columnIndex,
                          });
                        }}
                        className={[
                          "border border-black p-0 text-left align-top",
                          isSelected ? "outline outline-2 outline-black" : "",
                        ].join(" ")}
                        style={{
                          width: columnWidths[columnIndex],
                          minWidth: columnWidths[columnIndex],
                        }}
                      >
                        <div className="table-rich-cell">
                          <RichTextEditor
                            editorId={getCellEditorId(rowIndex, columnIndex)}
                            value={cell}
                            nodes={nodes}
                            editable={editable}
                            formatCommand={formatCommand}
                            onChange={(nextValue) =>
                              updateCell(rowIndex, columnIndex, nextValue)
                            }
                            onOpenNode={onOpenNode}
                            onActiveMarksChange={onRichTextMarksChange}
                            onActiveEditorChange={onActiveRichTextEditorChange}
                          />
                        </div>
                      </CellTag>
                    );
                  })}
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {!editable && (
        <div className="border-t border-black bg-neutral-100 p-2">
          <button
            type="button"
            onClick={exportCsv}
            className="border border-black bg-white px-3 py-1 text-sm hover:bg-black hover:text-white"
          >
            Export CSV
          </button>
        </div>
      )}
    </div>
  );
}
