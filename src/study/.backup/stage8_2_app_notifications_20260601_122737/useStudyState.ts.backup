import {
  useCallback,
  useEffect,
  useMemo,
  useRef,
  useState,
  type SetStateAction,
} from "react";
import { loadStudyStateFromJson, saveStudyStateToJson } from "../api/studyApi";
import { emptyStudyState } from "../data/defaultState";
import type {
  StudyBlock,
  StudyMaterial,
  StudyNode,
  StudyNodeType,
  StudyState,
} from "../types/study";
import { cloneBlock } from "../utils/blocks";
import { createId, now } from "../utils/ids";
import {
  collectDescendantIds,
  getTargetParentId,
  isDescendantNode,
} from "../utils/tree";
import { normalizeStudyState } from "../utils/studyStateValidation";

type SaveStatus = "loading" | "ready" | "saving" | "saved" | "error";

const MAX_TREE_DEPTH = 15;
const MAX_HISTORY_SIZE = 50;

function stringifyState(state: StudyState): string {
  return JSON.stringify(state);
}

function resolveStateAction(
  action: SetStateAction<StudyState>,
  previous: StudyState
): StudyState {
  return typeof action === "function"
    ? (action as (previous: StudyState) => StudyState)(previous)
    : action;
}

type CommitHistoryMode = "record" | "skip" | "merge";

interface CommitOptions {
  history?: CommitHistoryMode;
  historyKey?: string;
  mergeWindowMs?: number;
}

const DEFAULT_HISTORY_MERGE_WINDOW_MS = 1200;

export function useStudyState() {
  const [state, setState] = useState<StudyState>(() => normalizeStudyState(emptyStudyState));
  const [status, setStatus] = useState<SaveStatus>("loading");
  const [historyVersion, setHistoryVersion] = useState(0);

  const loadedRef = useRef(false);
  const lastSavedJsonRef = useRef("");
  const saveTimeoutRef = useRef<number | null>(null);

  const undoStackRef = useRef<StudyState[]>([]);
  const redoStackRef = useRef<StudyState[]>([]);
  const lastHistoryKeyRef = useRef<string | null>(null);
  const lastHistoryAtRef = useRef(0);

  const canUndo = undoStackRef.current.length > 0;
  const canRedo = redoStackRef.current.length > 0;

  const markHistoryChanged = useCallback(() => {
    setHistoryVersion((version) => version + 1);
  }, []);

  const commitState = useCallback((
    action: SetStateAction<StudyState>,
    options: CommitOptions = {}
  ) => {
    setState((previous) => {
      const normalizedPrevious = normalizeStudyState(previous);
      const nextState = normalizeStudyState(resolveStateAction(action, normalizedPrevious));

      if (stringifyState(normalizedPrevious) === stringifyState(nextState)) {
        return normalizedPrevious;
      }

      const historyMode = options.history ?? "record";

      if (historyMode === "skip") {
        return nextState;
      }

      const nowMs = Date.now();
      const mergeWindowMs = options.mergeWindowMs ?? DEFAULT_HISTORY_MERGE_WINDOW_MS;
      const historyKey = options.historyKey ?? null;

      const canMergeWithPreviousHistoryEntry =
        historyMode === "merge" &&
        historyKey !== null &&
        lastHistoryKeyRef.current === historyKey &&
        nowMs - lastHistoryAtRef.current <= mergeWindowMs &&
        undoStackRef.current.length > 0;

      if (!canMergeWithPreviousHistoryEntry) {
        undoStackRef.current = [
          ...undoStackRef.current.slice(-(MAX_HISTORY_SIZE - 1)),
          normalizedPrevious,
        ];
      }

      redoStackRef.current = [];
      lastHistoryKeyRef.current = historyKey;
      lastHistoryAtRef.current = nowMs;
      markHistoryChanged();

      return nextState;
    });
  }, [markHistoryChanged]);

  const undo = useCallback(() => {
    setState((current) => {
      const previous = undoStackRef.current.pop();

      if (!previous) {
        return current;
      }

      redoStackRef.current = [
        ...redoStackRef.current.slice(-(MAX_HISTORY_SIZE - 1)),
        normalizeStudyState(current),
      ];

      lastHistoryKeyRef.current = null;
      lastHistoryAtRef.current = 0;
      markHistoryChanged();

      return normalizeStudyState(previous);
    });
  }, [markHistoryChanged]);

  const redo = useCallback(() => {
    setState((current) => {
      const next = redoStackRef.current.pop();

      if (!next) {
        return current;
      }

      undoStackRef.current = [
        ...undoStackRef.current.slice(-(MAX_HISTORY_SIZE - 1)),
        normalizeStudyState(current),
      ];

      lastHistoryKeyRef.current = null;
      lastHistoryAtRef.current = 0;
      markHistoryChanged();

      return normalizeStudyState(next);
    });
  }, [markHistoryChanged]);

  useEffect(() => {
    let active = true;

    loadStudyStateFromJson()
      .then((loadedState) => {
        if (!active) return;

        const repairedState = normalizeStudyState(loadedState);

        undoStackRef.current = [];
        redoStackRef.current = [];
        lastHistoryKeyRef.current = null;
        lastHistoryAtRef.current = 0;
        markHistoryChanged();

        lastSavedJsonRef.current = stringifyState(repairedState);
        setState(repairedState);
        loadedRef.current = true;
        setStatus("saved");
      })
      .catch((error) => {
        console.error(error);

        if (!active) return;

        loadedRef.current = true;
        setStatus("error");
      });

    return () => {
      active = false;
    };
  }, [markHistoryChanged]);

  useEffect(() => {
    if (!loadedRef.current) {
      return;
    }

    const repairedState = normalizeStudyState(state);
    const nextJson = stringifyState(repairedState);

    if (nextJson === lastSavedJsonRef.current) {
      return;
    }

    if (saveTimeoutRef.current) {
      window.clearTimeout(saveTimeoutRef.current);
    }

    saveTimeoutRef.current = window.setTimeout(() => {
      setStatus("saving");

      saveStudyStateToJson(repairedState)
        .then((savedState) => {
          const normalizedSavedState = normalizeStudyState(savedState);

          lastSavedJsonRef.current = stringifyState(normalizedSavedState);
          setStatus("saved");
        })
        .catch((error) => {
          console.error(error);
          setStatus("error");
        });
    }, 600);

    return () => {
      if (saveTimeoutRef.current) {
        window.clearTimeout(saveTimeoutRef.current);
      }
    };
  }, [state]);

  const selectedNode = useMemo(() => {
    return state.nodes.find((node) => node.id === state.selectedNodeId) ?? null;
  }, [state.nodes, state.selectedNodeId]);

  const selectedMaterial = useMemo(() => {
    if (!selectedNode || selectedNode.type !== "material") {
      return null;
    }

    return state.materials.find((material) => material.nodeId === selectedNode.id) ?? null;
  }, [selectedNode, state.materials]);

  const selectNode = useCallback((nodeId: string) => {
    commitState(
      (previous) => ({
        ...previous,
        selectedNodeId: nodeId,
      }),
      {
        history: "skip",
      }
    );
  }, [commitState]);

  const createNode = useCallback(
    (type: StudyNodeType, title: string, explicitParentId?: string | null) => {
      commitState((previous) => {
        const parentId =
          explicitParentId === undefined
            ? getTargetParentId(previous.nodes, previous.selectedNodeId)
            : explicitParentId;

        let depth = 1;
        let parentIdCursor = parentId;

        while (parentIdCursor) {
          const parent = previous.nodes.find((node) => node.id === parentIdCursor);

          if (!parent) {
            break;
          }

          depth += 1;
          parentIdCursor = parent.parentId;
        }

        if (depth > MAX_TREE_DEPTH) {
          window.alert(`Нельзя создать уровень глубже ${MAX_TREE_DEPTH}.`);
          return previous;
        }

        const id = createId(type);
        const siblings = previous.nodes.filter((node) => node.parentId === parentId);

        const node: StudyNode = {
          id,
          type,
          title: title.trim(),
          parentId,
          order: siblings.length + 1,
          createdAt: now(),
          updatedAt: now(),
        };

        const nextState: StudyState = {
          ...previous,
          selectedNodeId: id,
          nodes: [...previous.nodes, node],
        };

        if (type === "material") {
          const material: StudyMaterial = {
            id,
            nodeId: id,
            title: title.trim(),
            tags: [],
            blocks: [],
            createdAt: now(),
            updatedAt: now(),
          };

          nextState.materials = [...previous.materials, material];
        }

        return nextState;
      });
    },
    [commitState]
  );

  const renameNode = useCallback((nodeId: string, title: string) => {
    commitState((previous) => ({
      ...previous,
      nodes: previous.nodes.map((node) =>
        node.id === nodeId
          ? {
              ...node,
              title,
              updatedAt: now(),
            }
          : node
      ),
      materials: previous.materials.map((material) =>
        material.nodeId === nodeId
          ? {
              ...material,
              title,
              updatedAt: now(),
            }
          : material
      ),
    }));
  }, [commitState]);

  const deleteNode = useCallback((nodeId: string) => {
    commitState((previous) => {
      const idsToDelete = collectDescendantIds(previous.nodes, nodeId);
      idsToDelete.add(nodeId);

      const nodes = previous.nodes.filter((node) => !idsToDelete.has(node.id));
      const materials = previous.materials.filter(
        (material) => !idsToDelete.has(material.nodeId)
      );

      const selectedNodeId = idsToDelete.has(previous.selectedNodeId ?? "")
        ? nodes[0]?.id ?? null
        : previous.selectedNodeId;

      return {
        ...previous,
        nodes,
        materials,
        selectedNodeId,
      };
    });
  }, [commitState]);

  const duplicateMaterial = useCallback((nodeId: string) => {
    commitState((previous) => {
      const sourceNode = previous.nodes.find((node) => node.id === nodeId);
      const sourceMaterial = previous.materials.find(
        (material) => material.nodeId === nodeId
      );

      if (!sourceNode || sourceNode.type !== "material" || !sourceMaterial) {
        return previous;
      }

      const newNodeId = createId("material");
      const copiedTitle = `${sourceNode.title} copy`;
      const siblings = previous.nodes.filter(
        (node) => node.parentId === sourceNode.parentId
      );

      const newNode: StudyNode = {
        ...sourceNode,
        id: newNodeId,
        title: copiedTitle,
        order: siblings.length + 1,
        createdAt: now(),
        updatedAt: now(),
      };

      const newMaterial: StudyMaterial = {
        ...sourceMaterial,
        id: newNodeId,
        nodeId: newNodeId,
        title: copiedTitle,
        blocks: sourceMaterial.blocks.map(cloneBlock),
        createdAt: now(),
        updatedAt: now(),
      };

      return {
        ...previous,
        selectedNodeId: newNodeId,
        nodes: [...previous.nodes, newNode],
        materials: [...previous.materials, newMaterial],
      };
    });
  }, [commitState]);

  const moveNode = useCallback((draggedNodeId: string, targetNodeId: string | null) => {
    commitState((previous) => {
      const draggedNode = previous.nodes.find((node) => node.id === draggedNodeId);

      if (!draggedNode) {
        return previous;
      }

      let newParentId: string | null = null;

      if (targetNodeId) {
        const targetNode = previous.nodes.find((node) => node.id === targetNodeId);

        if (!targetNode) {
          return previous;
        }

        newParentId = targetNode.type === "folder" ? targetNode.id : targetNode.parentId;
      }

      if (newParentId === draggedNodeId) {
        window.alert("Нельзя переместить элемент внутрь самого себя.");
        return previous;
      }

      if (newParentId && isDescendantNode(previous.nodes, newParentId, draggedNodeId)) {
        window.alert("Нельзя переместить папку внутрь её дочерней папки.");
        return previous;
      }

      const siblings = previous.nodes.filter(
        (node) => node.parentId === newParentId && node.id !== draggedNodeId
      );

      return {
        ...previous,
        selectedNodeId: draggedNodeId,
        nodes: previous.nodes.map((node) =>
          node.id === draggedNodeId
            ? {
                ...node,
                parentId: newParentId,
                order: siblings.length + 1,
                updatedAt: now(),
              }
            : node
        ),
      };
    });
  }, [commitState]);

  const updateMaterial = useCallback((material: StudyMaterial) => {
    commitState(
      (previous) => ({
        ...previous,
        materials: previous.materials.map((item) =>
          item.id === material.id
            ? {
                ...material,
                updatedAt: now(),
              }
            : item
        ),
      }),
      {
        history: "merge",
        historyKey: `material:${material.id}`,
      }
    );
  }, [commitState]);

  const updateMaterialTitle = useCallback((nodeId: string, title: string) => {
    commitState(
      (previous) => ({
        ...previous,
        nodes: previous.nodes.map((node) =>
          node.id === nodeId
            ? {
                ...node,
                title,
                updatedAt: now(),
              }
            : node
        ),
        materials: previous.materials.map((material) =>
          material.nodeId === nodeId
            ? {
                ...material,
                title,
                updatedAt: now(),
              }
            : material
        ),
      }),
      {
        history: "merge",
        historyKey: `material-title:${nodeId}`,
      }
    );
  }, [commitState]);

  const addBlock = useCallback((materialId: string, block: StudyBlock) => {
    commitState((previous) => ({
      ...previous,
      materials: previous.materials.map((material) =>
        material.id === materialId
          ? {
              ...material,
              blocks: [...material.blocks, block],
              updatedAt: now(),
            }
          : material
      ),
    }));
  }, [commitState]);

  const updateBlock = useCallback(
    (materialId: string, blockId: string, updatedBlock: StudyBlock) => {
      commitState(
        (previous) => ({
          ...previous,
          materials: previous.materials.map((material) =>
            material.id === materialId
              ? {
                  ...material,
                  blocks: material.blocks.map((block) =>
                    block.id === blockId
                      ? {
                          ...updatedBlock,
                          updatedAt: now(),
                        }
                      : block
                  ),
                  updatedAt: now(),
                }
              : material
          ),
        }),
        {
          history: "merge",
          historyKey: `block:${materialId}:${blockId}`,
        }
      );
    },
    [commitState]
  );

  const deleteBlock = useCallback((materialId: string, blockId: string) => {
    commitState((previous) => ({
      ...previous,
      materials: previous.materials.map((material) =>
        material.id === materialId
          ? {
              ...material,
              blocks: material.blocks.filter((block) => block.id !== blockId),
              updatedAt: now(),
            }
          : material
      ),
    }));
  }, [commitState]);

  const duplicateBlock = useCallback((materialId: string, blockId: string) => {
    commitState((previous) => ({
      ...previous,
      materials: previous.materials.map((material) => {
        if (material.id !== materialId) {
          return material;
        }

        const index = material.blocks.findIndex((block) => block.id === blockId);

        if (index < 0) {
          return material;
        }

        return {
          ...material,
          blocks: [
            ...material.blocks.slice(0, index + 1),
            cloneBlock(material.blocks[index]),
            ...material.blocks.slice(index + 1),
          ],
          updatedAt: now(),
        };
      }),
    }));
  }, [commitState]);

  const moveBlock = useCallback(
    (materialId: string, blockId: string, direction: -1 | 1) => {
      commitState((previous) => ({
        ...previous,
        materials: previous.materials.map((material) => {
          if (material.id !== materialId) {
            return material;
          }

          const index = material.blocks.findIndex((block) => block.id === blockId);
          const targetIndex = index + direction;

          if (index < 0 || targetIndex < 0 || targetIndex >= material.blocks.length) {
            return material;
          }

          const blocks = [...material.blocks];
          const current = blocks[index];

          blocks[index] = blocks[targetIndex];
          blocks[targetIndex] = current;

          return {
            ...material,
            blocks,
            updatedAt: now(),
          };
        }),
      }));
    },
    [commitState]
  );

  return {
    state,
    status,
    selectedNode,
    selectedMaterial,
    historyVersion,
    actions: {
      setState: commitState,
      undo,
      redo,
      canUndo,
      canRedo,
      selectNode,
      createNode,
      renameNode,
      deleteNode,
      duplicateMaterial,
      moveNode,
      updateMaterial,
      updateMaterialTitle,
      addBlock,
      updateBlock,
      deleteBlock,
      duplicateBlock,
      moveBlock,
    },
  };
}
