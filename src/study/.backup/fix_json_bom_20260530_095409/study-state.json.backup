        },
        {
          "id": "block_text_1",
          "type": "text",
          "content": "Кинематика изучает движение тел без рассмотрения причин движения. Для связи с другой темой можно написать [[Динамика]]. Эта ссылка должна открывать материал Динамика.",
          "createdAt": "2026-05-30T00:00:00.000Z",
          "updatedAt": "2026-05-30T00:00:00.000Z"
        },
        {
          "id": "block_formula_1",
          "type": "latex",
          "content": "v = \\\\frac{s}{t}",
          "createdAt": "2026-05-30T00:00:00.000Z",
          "updatedAt": "2026-05-30T00:00:00.000Z"
        }
      ]
    },
