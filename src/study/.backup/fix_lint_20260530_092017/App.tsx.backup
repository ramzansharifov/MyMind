    customBlockTemplates: createDefaultTemplates(),
    nodes: [
      {
        id: "folder_physics",
        type: "folder",
        title: "Физика",
        parentId: null,
        order: 1,
        createdAt: now(),
        updatedAt: now(),
      },
      {
        id: "folder_mechanics",
        type: "folder",
        title: "Механика",
        parentId: "folder_physics",
        order: 1,
        createdAt: now(),
        updatedAt: now(),
      },
      {
        id: "material_kinematics",
        type: "material",
        title: "Кинематика",
