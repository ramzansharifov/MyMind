import {
  useEffect,
  useMemo,
  useRef,
  useState,
  type DragEvent,
  type KeyboardEvent,
  type PointerEvent,
} from "react";

type StudyNodeType = "folder" | "material";

type StudyBlockType =
  | "heading"
  | "text"
  | "latex"
  | "definition"
  | "problem"
  | "solution"
  | "board"
  | "file"
  | "divider"
  | "custom";

type CustomFieldType =
  | "text"
  | "long_text"
  | "latex"
  | "number"
  | "checkbox"
  | "select"
  | "date"
  | "link";

type CustomBlockValue = string | number | boolean;

interface CustomBlockField {
  id: string;
  label: string;
  type: CustomFieldType;
  required?: boolean;
  placeholder?: string;
  options?: string[];
}

interface CustomBlockTemplate {
  id: string;
  name: string;
  icon: string;
  color: string;
  description?: string;
  fields: CustomBlockField[];
  createdAt: string;
  updatedAt: string;
}

interface StudyNode {
  id: string;
  type: StudyNodeType;
  title: string;
  parentId: string | null;
  order: number;
  createdAt: string;
  updatedAt: string;
}

interface BoardPoint {
  x: number;
  y: number;
}

interface BoardStroke {
  id: string;
  points: BoardPoint[];
  width: number;
}

interface StudyBlockBase<T extends StudyBlockType> {
  id: string;
  type: T;
  createdAt: string;
  updatedAt: string;
}

interface ContentStudyBlock
  extends StudyBlockBase<
    "heading" | "text" | "latex" | "definition" | "problem" | "solution"
  > {
  content: string;
}

interface BoardStudyBlock extends StudyBlockBase<"board"> {
  title: string;
  strokes: BoardStroke[];
}

interface FileStudyBlock extends StudyBlockBase<"file"> {
  fileName: string;
  note: string;
  mimeType: string;
  size: number;
  dataUrl: string;
}

interface DividerStudyBlock extends StudyBlockBase<"divider"> {}

interface CustomStudyBlock extends StudyBlockBase<"custom"> {
  templateId: string;
  values: Record<string, CustomBlockValue>;
}

type StudyBlock =
  | ContentStudyBlock
  | BoardStudyBlock
  | FileStudyBlock
  | DividerStudyBlock
  | CustomStudyBlock;

interface StudyMaterial {
  id: string;
  nodeId: string;
  title: string;
  blocks: StudyBlock[];
  tags: string[];
  createdAt: string;
  updatedAt: string;
}

interface StudyState {
  nodes: StudyNode[];
  materials: StudyMaterial[];
  selectedNodeId: string | null;
  customBlockTemplates: CustomBlockTemplate[];
}

const STORAGE_KEY = "mymind-study-module-state-v1";
const MAX_TREE_DEPTH = 15;
const MAX_FILE_SIZE = 5 * 1024 * 1024;

const now = () => new Date().toISOString();

function createId(prefix: string) {
  return `${prefix}_${Date.now()}_${Math.random().toString(36).slice(2, 9)}`;
}

