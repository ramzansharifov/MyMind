@import "tailwindcss";

* {
  box-sizing: border-box;
}

html,
body,
#root {
  min-height: 100%;
}

body {
  margin: 0;
  background: #ffffff;
  color: #000000;
  font-family: Arial, Helvetica, sans-serif;
}

button,
input,
textarea,
select {
  font: inherit;
}

button {
  cursor: pointer;
}

textarea {
  resize: vertical;
}
.rich-text-editor:empty::before {
  content: attr(data-placeholder);
  color: #777777;
}

.rich-text-editor p,
.rich-text-view p {
  margin: 0 0 0.75rem 0;
}

.rich-text-editor ul,
.rich-text-editor ol,
.rich-text-view ul,
.rich-text-view ol {
  margin: 0.5rem 0 0.75rem 1.5rem;
  padding-left: 1.25rem;
}

.rich-text-editor li,
.rich-text-view li {
  margin: 0.25rem 0;
}

.rich-text-editor blockquote,
.rich-text-view blockquote {
  margin: 0.75rem 0;
  padding-left: 1rem;
  border-left: 3px solid #000000;
  color: #333333;
}

.rich-text-editor b,
.rich-text-editor strong,
.rich-text-view b,
.rich-text-view strong {
  font-weight: 700;
}

.rich-text-editor i,
.rich-text-editor em,
.rich-text-view i,
.rich-text-view em {
  font-style: italic;
}

.rich-text-editor u,
.rich-text-view u {
  text-decoration: underline;
}

.rich-text-editor s,
.rich-text-editor strike,
.rich-text-view s,
.rich-text-view strike {
  text-decoration: line-through;
}

/* Rich text editor improvements */
.rich-text-editor,
.rich-text-view {
  word-break: break-word;
}

.rich-text-editor p,
.rich-text-view p {
  margin: 0 0 0.35rem 0;
}

.rich-text-editor p + p,
.rich-text-view p + p {
  margin-top: 0.15rem;
}

.rich-text-editor ul,
.rich-text-view ul {
  list-style-type: disc;
  list-style-position: outside;
  margin: 0.35rem 0 0.5rem 1.35rem;
  padding-left: 1.25rem;
}

.rich-text-editor ol,
.rich-text-view ol {
  list-style-type: decimal;
  list-style-position: outside;
  margin: 0.35rem 0 0.5rem 1.35rem;
  padding-left: 1.25rem;
}

.rich-text-editor li,
.rich-text-view li {
  display: list-item;
  margin: 0.12rem 0;
  padding-left: 0.15rem;
}

.rich-text-editor li p,
.rich-text-view li p {
  margin: 0;
}

.rich-text-editor blockquote,
.rich-text-view blockquote {
  margin: 0.45rem 0;
  padding: 0.35rem 0 0.35rem 1rem;
  border-left: 3px solid #000000;
  color: #333333;
  background: #f5f5f5;
}

.rich-text-editor blockquote p,
.rich-text-view blockquote p {
  margin: 0.15rem 0;
}

.rich-text-editor b,
.rich-text-editor strong,
.rich-text-view b,
.rich-text-view strong {
  font-weight: 700;
}

.rich-text-editor i,
.rich-text-editor em,
.rich-text-view i,
.rich-text-view em {
  font-style: italic;
}

.rich-text-editor u,
.rich-text-view u {
  text-decoration: underline;
}

.rich-text-editor s,
.rich-text-editor strike,
.rich-text-view s,
.rich-text-view strike {
  text-decoration: line-through;
}

/* Markdown block */
.markdown-view {
  line-height: 1.7;
}

.markdown-view h1 {
  margin: 0.7rem 0 0.5rem;
  font-size: 2rem;
  font-weight: 900;
  border-bottom: 2px solid #000000;
  padding-bottom: 0.35rem;
}

.markdown-view h2 {
  margin: 0.7rem 0 0.45rem;
  font-size: 1.55rem;
  font-weight: 800;
  border-bottom: 1px solid #000000;
  padding-bottom: 0.25rem;
}

.markdown-view h3 {
  margin: 0.6rem 0 0.35rem;
  font-size: 1.25rem;
  font-weight: 800;
}

.markdown-view p {
  margin: 0.35rem 0;
}

.markdown-view ul,
.markdown-view ol {
  margin: 0.4rem 0 0.6rem 1.4rem;
  padding-left: 1.2rem;
}

.markdown-view ul {
  list-style-type: disc;
}

.markdown-view ol {
  list-style-type: decimal;
}

.markdown-view li {
  display: list-item;
  margin: 0.15rem 0;
}

.markdown-view blockquote {
  margin: 0.5rem 0;
  padding: 0.4rem 0 0.4rem 1rem;
  border-left: 3px solid #000000;
  background: #f5f5f5;
}

.markdown-view code {
  border: 1px solid #000000;
  background: #f5f5f5;
  padding: 0 0.25rem;
  font-family: "Courier New", Consolas, monospace;
}

.markdown-view pre {
  overflow: auto;
  border: 1px solid #000000;
  background: #f5f5f5;
  padding: 0.75rem;
}

.markdown-view pre code {
  border: 0;
  padding: 0;
}

/* Markdown block with react-markdown + remark-gfm */
.markdown-view {
  line-height: 1.7;
}

.markdown-view h1 {
  margin: 0.8rem 0 0.5rem;
  font-size: 2rem;
  font-weight: 900;
  border-bottom: 2px solid #000000;
  padding-bottom: 0.35rem;
}

.markdown-view h2 {
  margin: 0.75rem 0 0.45rem;
  font-size: 1.55rem;
  font-weight: 800;
  border-bottom: 1px solid #000000;
  padding-bottom: 0.25rem;
}

.markdown-view h3 {
  margin: 0.65rem 0 0.35rem;
  font-size: 1.25rem;
  font-weight: 800;
}

.markdown-view h4,
.markdown-view h5,
.markdown-view h6 {
  margin: 0.55rem 0 0.3rem;
  font-weight: 800;
}

.markdown-view p {
  margin: 0.35rem 0;
}

.markdown-view ul,
.markdown-view ol {
  margin: 0.4rem 0 0.6rem 1.4rem;
  padding-left: 1.2rem;
}

.markdown-view ul {
  list-style-type: disc;
}

.markdown-view ol {
  list-style-type: decimal;
}

.markdown-view li {
  display: list-item;
  margin: 0.15rem 0;
}

.markdown-view blockquote {
  margin: 0.5rem 0;
  padding: 0.4rem 0 0.4rem 1rem;
  border-left: 3px solid #000000;
  background: #f5f5f5;
}

.markdown-view code {
  border: 1px solid #000000;
  background: #f5f5f5;
  padding: 0 0.25rem;
  font-family: "Courier New", Consolas, monospace;
}

.markdown-view pre {
  overflow: auto;
  border: 1px solid #000000;
  background: #f5f5f5;
  padding: 0.75rem;
}

.markdown-view pre code {
  border: 0;
  padding: 0;
}

.markdown-view table {
  width: 100%;
  border-collapse: collapse;
  margin: 0.75rem 0;
  font-size: 0.95rem;
}

.markdown-view th,
.markdown-view td {
  border: 1px solid #000000;
  padding: 0.45rem 0.6rem;
  text-align: left;
  vertical-align: top;
}

.markdown-view th {
  background: #f5f5f5;
  font-weight: 800;
}

.markdown-view a {
  text-decoration: underline;
  color: #000000;
}

.markdown-view hr {
  border: 0;
  border-top: 1px solid #000000;
  margin: 1rem 0;
}

.markdown-view input[type="checkbox"] {
  margin-right: 0.4rem;
}

/* Rich text internet links */
.rich-text-editor a,
.rich-text-view a {
  text-decoration: underline;
  color: #000000;
  font-weight: 600;
}

/* Rich text inside flexible table cells */
.table-rich-cell .rich-text-editor {
  min-height: 56px;
  border: 0;
}

.table-rich-cell .rich-text-view {
  min-height: 40px;
  padding: 0.5rem;
}

.table-rich-cell .rich-text-view p,
.table-rich-cell .rich-text-editor p {
  margin: 0 0 0.25rem 0;
}

.table-rich-cell .rich-text-view ul,
.table-rich-cell .rich-text-view ol,
.table-rich-cell .rich-text-editor ul,
.table-rich-cell .rich-text-editor ol {
  margin-top: 0.25rem;
  margin-bottom: 0.25rem;
}

/* Custom ordered list marker: 1) */
@counter-style decimal-parenthesis {
  system: extends decimal;
  suffix: ") ";
}

.rich-text-editor ol,
.rich-text-view ol {
  list-style-position: outside;
}

/* Checkbox / task-list marker */
@counter-style checkbox-list {
  system: cyclic;
  symbols: "☐";
  suffix: " ";
}

.rich-text-editor ul[style*="checkbox-list"],
.rich-text-view ul[style*="checkbox-list"] {
  list-style-type: checkbox-list;
}

/* Clickable checkbox / task-list items */
.rich-text-editor ul[style*="checkbox-list"],
.rich-text-view ul[style*="checkbox-list"],
.rich-text-editor ul[data-list-type="checkbox"],
.rich-text-view ul[data-list-type="checkbox"] {
  list-style-type: none !important;
  margin-left: 0;
  padding-left: 0;
}

.rich-text-editor ul[style*="checkbox-list"] > li,
.rich-text-view ul[style*="checkbox-list"] > li,
.rich-text-editor ul[data-list-type="checkbox"] > li,
.rich-text-view ul[data-list-type="checkbox"] > li {
  position: relative;
  display: list-item;
  min-height: 1.6em;
  padding-left: 1.8rem;
  cursor: text;
}

.rich-text-editor ul[style*="checkbox-list"] > li::before,
.rich-text-view ul[style*="checkbox-list"] > li::before,
.rich-text-editor ul[data-list-type="checkbox"] > li::before,
.rich-text-view ul[data-list-type="checkbox"] > li::before {
  content: "☐";
  position: absolute;
  left: 0;
  top: 0;
  width: 1.4rem;
  cursor: pointer;
  font-weight: 700;
  text-align: center;
}

.rich-text-editor ul[style*="checkbox-list"] > li[data-checked="true"]::before,
.rich-text-view ul[style*="checkbox-list"] > li[data-checked="true"]::before,
.rich-text-editor ul[data-list-type="checkbox"] > li[data-checked="true"]::before,
.rich-text-view ul[data-list-type="checkbox"] > li[data-checked="true"]::before {
  content: "☑";
}

.rich-text-editor ul[style*="checkbox-list"] > li[data-checked="true"],
.rich-text-view ul[style*="checkbox-list"] > li[data-checked="true"],
.rich-text-editor ul[data-list-type="checkbox"] > li[data-checked="true"],
.rich-text-view ul[data-list-type="checkbox"] > li[data-checked="true"] {
  opacity: 0.75;
}

.rich-text-editor ul[style*="checkbox-list"] > li[data-checked="true"] > *,
.rich-text-view ul[style*="checkbox-list"] > li[data-checked="true"] > *,
.rich-text-editor ul[data-list-type="checkbox"] > li[data-checked="true"] > *,
.rich-text-view ul[data-list-type="checkbox"] > li[data-checked="true"] > * {
  text-decoration: line-through;
}

/* Read mode print / PDF */
@media print {
  body {
    background: #ffffff !important;
  }

  aside,
  nav,
  .read-page-toolbar,
  .read-page-toc,
  .topbar,
  .sidebar,
  [data-print-hidden="true"] {
    display: none !important;
  }

  .read-page-sheet {
    border: 0 !important;
    box-shadow: none !important;
    max-width: none !important;
    width: 100% !important;
    padding: 0 !important;
  }

  @page {
    margin: 18mm;
  }
}
