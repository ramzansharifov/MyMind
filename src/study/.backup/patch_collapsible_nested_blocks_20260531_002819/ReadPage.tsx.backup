import type {
  CustomBlockTemplate,
  StudyBlock,
  StudyNode,
} from "../../types/study";
import { BlockRenderer } from "./BlockRenderer";

interface ReadPageProps {
  title: string;
  tags: string[];
  blocks: StudyBlock[];
  nodes: StudyNode[];
  templates: CustomBlockTemplate[];
  pageWidth: number;
  onOpenNode: (nodeId: string) => void;
}

function getReadBlockSpacing(block: StudyBlock): string {
  if (block.type === "heading") {
    return "mt-9 first:mt-0";
  }

  if (block.type === "divider") {
    return "my-8";
  }

  if (block.type === "board" || block.type === "file") {
    return "my-8";
  }

  if (block.type === "code" || block.type === "latex") {
    return "my-6";
  }

  return "my-4";
}

function renderReadBlocks(
  blocks: StudyBlock[],
  nodes: StudyNode[],
  templates: CustomBlockTemplate[],
  onOpenNode: (nodeId: string) => void,
  level = 0
) {
  return blocks.map((block) => (
    <section
      key={block.id}
      className={getReadBlockSpacing(block)}
    >
      <BlockRenderer
        block={block}
        nodes={nodes}
        templates={templates}
        editable={false}
        onChange={() => {}}
        onOpenNode={onOpenNode}
      />

      {(block.children?.length ?? 0) > 0 && (
        <div
          className={
            level === 0
              ? "mt-4 border-l border-black pl-5"
              : "mt-4 border-l border-neutral-400 pl-5"
          }
        >
          {renderReadBlocks(block.children ?? [], nodes, templates, onOpenNode, level + 1)}
        </div>
      )}
    </section>
  ));
}

export function ReadPage({
  title,
  tags,
  blocks,
  nodes,
  templates,
  pageWidth,
  onOpenNode,
}: ReadPageProps) {
  return (
    <article
      className="mx-auto border border-black bg-white px-14 py-12"
      style={{
        maxWidth: pageWidth,
      }}
    >
      <header className="mb-10 border-b border-black pb-6">
        <h1 className="text-4xl font-black leading-tight">
          {title}
        </h1>

        {tags.length > 0 && (
          <div className="mt-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span
                key={tag}
                className="border border-black bg-white px-2 py-1 text-xs"
              >
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      {blocks.length === 0 && (
        <p className="text-neutral-600">
          В этом материале пока нет содержимого.
        </p>
      )}

      <div className="leading-7">
        {renderReadBlocks(blocks, nodes, templates, onOpenNode)}
      </div>
    </article>
  );
}
