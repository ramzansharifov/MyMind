import type {
  BlockSettings,
  BlockTextAlign,
  CustomBlockTemplate,
  HeadingStyle,
  StudyBlock,
} from "../../types/study";
import { getBlockTitle } from "../../utils/blocks";
import {
  createBlock,
  createCustomBlock,
  type SystemBlockType,
} from "../../utils/blocks";
import type {
  RichTextActiveMarks,
  RichTextCommandType,
} from "./RichTextEditor";

interface BlockSettingsPanelProps {
  block: StudyBlock | null;
  templates: CustomBlockTemplate[];
  richTextMarks?: RichTextActiveMarks;
  childrenCount?: number;
  onRichTextCommand?: (command: RichTextCommandType, value?: string) => void;
  onAddChildBlock?: (block: StudyBlock) => void;
  onChangeSettings: (settings: BlockSettings) => void;
}

const childSystemBlocks: Array<{
  type: SystemBlockType;
  label: string;
}> = [
  { type: "heading", label: "Заголовок" },
  { type: "text", label: "Текст" },
  { type: "latex", label: "LaTeX" },
  { type: "markdown", label: "Markdown" },
  { type: "code", label: "Код" },
  { type: "table", label: "Таблица" },
  { type: "board", label: "Доска" },
  { type: "file", label: "Файл" },
  { type: "divider", label: "Линия" },
];

const codeLanguages = [
  "plain",
  "javascript",
  "typescript",
  "tsx",
  "jsx",
  "html",
  "css",
  "json",
  "python",
  "cpp",
  "java",
  "sql",
  "bash",
  "powershell",
];

function getSettings(block: StudyBlock | null): BlockSettings {
  return block?.settings ?? {};
}

function getToolButtonClass(active: boolean): string {
  return active
    ? "border border-black bg-black px-2 py-1 text-sm text-white"
    : "border border-black bg-white px-2 py-1 text-sm hover:bg-black hover:text-white";
}

function NumberSetting({
  label,
  value,
  min,
  max,
  placeholder,
  onChange,
}: {
  label: string;
  value: number | undefined;
  min: number;
  max: number;
  placeholder: string;
  onChange: (value: number | undefined) => void;
}) {
  return (
    <label className="block">
      <span className="mb-1 block text-sm font-bold">{label}</span>
      <input
        type="number"
        min={min}
        max={max}
        value={value ?? ""}
        placeholder={placeholder}
        onChange={(event) => {
          const rawValue = event.target.value;

          if (!rawValue) {
            onChange(undefined);
            return;
          }

          const nextValue = Math.min(max, Math.max(min, Number(rawValue)));
          onChange(nextValue);
        }}
        className="w-full border border-black bg-white px-3 py-2 outline-none"
      />
      <p className="mt-1 text-xs text-neutral-600">
        Диапазон: {min}–{max}
      </p>
    </label>
  );
}

function ColorSetting({
  label,
  value,
  defaultValue,
  onChange,
}: {
  label: string;
  value: string | undefined;
  defaultValue: string;
  onChange: (value: string | undefined) => void;
}) {
  return (
    <label className="block">
      <span className="mb-1 block text-sm font-bold">{label}</span>
      <div className="flex gap-2">
        <input
          type="color"
          value={value ?? defaultValue}
          onChange={(event) => onChange(event.target.value)}
          className="h-10 w-16 border border-black bg-white"
        />
        <button
          type="button"
          onClick={() => onChange(undefined)}
          className="flex-1 border border-black bg-white px-3 py-2 text-sm hover:bg-black hover:text-white"
        >
          Сбросить
        </button>
      </div>
    </label>
  );
}

function AlignSetting({
  value,
  onChange,
}: {
  value: BlockTextAlign | undefined;
  onChange: (value: BlockTextAlign | undefined) => void;
}) {
  return (
    <label className="block">
      <span className="mb-1 block text-sm font-bold">Выравнивание</span>
      <select
        value={value ?? "left"}
        onChange={(event) => onChange(event.target.value as BlockTextAlign)}
        className="w-full border border-black bg-white px-3 py-2 outline-none"
      >
        <option value="left">Слева</option>
        <option value="center">По центру</option>
        <option value="right">Справа</option>
      </select>
    </label>
  );
}

export function BlockSettingsPanel({
  block,
  templates,
  richTextMarks,
  childrenCount = 0,
  onRichTextCommand,
  onAddChildBlock,
  onChangeSettings,
}: BlockSettingsPanelProps) {
  if (!block) {
    return (
      <aside className="sticky top-[72px] max-h-[calc(100vh-84px)] overflow-auto border border-black bg-white p-4">
        <h3 className="font-bold">Настройки блока</h3>
        <p className="mt-3 text-sm text-neutral-600">
          Выбери блок слева, чтобы изменить его оформление.
        </p>
      </aside>
    );
  }

  const settings = getSettings(block);

  function updateSetting<K extends keyof BlockSettings>(
    key: K,
    value: BlockSettings[K]
  ) {
    onChangeSettings({
      ...settings,
      [key]: value,
    });
  }

  function resetSettings() {
    onChangeSettings({});
  }

  function runRichCommand(command: RichTextCommandType, value?: string) {
    onRichTextCommand?.(command, value);
  }

  const isHeading = block.type === "heading";
  const isText = block.type === "text";
  const isLatex = block.type === "latex";
  const isMarkdown = block.type === "markdown";
  const isCode = block.type === "code";
  const isTable = block.type === "table";
  const isBoard = block.type === "board";
  const isFile = block.type === "file";
  const isCustom = block.type === "custom";

  const marks = richTextMarks ?? {
    bold: false,
    italic: false,
    underline: false,
    strikeThrough: false,
    unorderedList: false,
    orderedList: false,
    quote: false,
    listStyle: "disc",
  };

  return (
    <aside className="sticky top-[72px] max-h-[calc(100vh-84px)] overflow-auto border border-black bg-white">
      <div className="border-b border-black bg-neutral-100 px-4 py-3">
        <h3 className="font-bold">Настройки блока</h3>
        <p className="mt-1 text-sm text-neutral-600">
          {getBlockTitle(block)}
        </p>
      </div>

      <div className="space-y-4 p-4">
        <section className="border border-black bg-white p-3">
          <h4 className="mb-2 font-bold">Вложенные блоки</h4>

          <p className="mb-3 text-xs text-neutral-600">
            Сейчас внутри блока: {childrenCount}. Новый блок будет добавлен внутрь выбранного блока.
          </p>

          <div className="grid grid-cols-2 gap-2">
            {childSystemBlocks.map((item) => (
              <button
                key={item.type}
                type="button"
                onClick={() => onAddChildBlock?.(createBlock(item.type))}
                className="border border-black bg-white px-2 py-2 text-sm hover:bg-black hover:text-white"
              >
                + {item.label}
              </button>
            ))}
          </div>

          {templates.length > 0 && (
            <div className="mt-3 border-t border-black pt-3">
              <p className="mb-2 text-xs font-bold">Кастомные блоки</p>

              <div className="space-y-2">
                {templates.map((template) => (
                  <button
                    key={template.id}
                    type="button"
                    onClick={() => onAddChildBlock?.(createCustomBlock(template))}
                    className="block w-full border border-black bg-white px-2 py-2 text-left text-sm hover:bg-black hover:text-white"
                  >
                    + [{template.icon || "B"}] {template.name}
                  </button>
                ))}
              </div>
            </div>
          )}
        </section>

        {isText && (
          <section className="border border-black bg-white p-3">
            <h4 className="mb-3 font-bold">Форматирование текста</h4>

            <p className="mb-3 text-xs text-neutral-600">
              Выдели часть текста внутри блока и нажми нужное действие здесь.
            </p>

            <div className="flex flex-wrap gap-1">
              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("paragraph")} className={getToolButtonClass(false)}>
                P
              </button>

              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("bold")} className={getToolButtonClass(marks.bold)}>
                <span className="font-bold">B</span>
              </button>

              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("italic")} className={getToolButtonClass(marks.italic)}>
                <span className="italic">I</span>
              </button>

              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("underline")} className={getToolButtonClass(marks.underline)}>
                <span className="underline">U</span>
              </button>

              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("strikeThrough")} className={getToolButtonClass(marks.strikeThrough)}>
                <span className="line-through">S</span>
              </button>

              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("unorderedList", marks.listStyle || "disc")} className={getToolButtonClass(marks.unorderedList)}>
                • List
              </button>

              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("orderedList", marks.listStyle === "disc" ? "decimal" : marks.listStyle)} className={getToolButtonClass(marks.orderedList)}>
                1. List
              </button>

              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("quote")} className={getToolButtonClass(marks.quote)}>
                Quote
              </button>

              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("clearFormat")} className={getToolButtonClass(false)}>
                Clear
              </button>
            </div>

            <label className="mt-3 block">
              <span className="mb-1 block text-sm font-bold">Стиль списка</span>
              <select
                value={marks.listStyle || "disc"}
                onMouseDown={(event) => event.preventDefault()}
                onChange={(event) => runRichCommand("listStyle", event.target.value)}
                className="w-full border border-black bg-white px-2 py-2 text-sm outline-none"
              >
                <option value="disc">disc</option>
                <option value="circle">circle</option>
                <option value="square">square</option>
                <option value="decimal">decimal</option>
                <option value="lower-alpha">lower-alpha</option>
                <option value="upper-alpha">upper-alpha</option>
                <option value="lower-roman">lower-roman</option>
                <option value="upper-roman">upper-roman</option>
              </select>
            </label>
          </section>
        )}

        {isHeading && (
          <section className="border border-black bg-white p-3">
            <h4 className="mb-3 font-bold">Стиль заголовка</h4>

            <label className="block">
              <span className="mb-1 block text-sm font-bold">Тип заголовка</span>
              <select
                value={settings.headingStyle ?? "h1"}
                onChange={(event) =>
                  updateSetting("headingStyle", event.target.value as HeadingStyle)
                }
                className="w-full border border-black bg-white px-3 py-2 outline-none"
              >
                <option value="h1">H1 — главный заголовок</option>
                <option value="h2">H2 — раздел</option>
                <option value="h3">H3 — подпункт</option>
              </select>
            </label>
          </section>
        )}

        {(isHeading || isText || isLatex || isMarkdown || isCode) && (
          <NumberSetting
            label={isHeading ? "Размер заголовка" : isCode ? "Размер кода" : isLatex ? "Размер LaTeX" : isMarkdown ? "Размер Markdown" : "Размер текста"}
            value={settings.fontSize}
            min={isHeading ? 18 : isCode ? 11 : 12}
            max={isHeading ? 42 : isCode ? 22 : isLatex ? 34 : 28}
            placeholder={isHeading ? "Авто по H1/H2/H3" : isText ? "16" : isLatex ? "20" : isMarkdown ? "16" : "14"}
            onChange={(value) => updateSetting("fontSize", value)}
          />
        )}

        {(isHeading || isText || isLatex || isMarkdown || isCode || isCustom) && (
          <ColorSetting
            label="Цвет текста"
            value={settings.textColor}
            defaultValue="#000000"
            onChange={(value) => updateSetting("textColor", value)}
          />
        )}

        <ColorSetting
          label="Цвет фона блока"
          value={settings.backgroundColor}
          defaultValue="#ffffff"
          onChange={(value) => updateSetting("backgroundColor", value)}
        />

        {(isHeading || isText || isLatex || isMarkdown || isCode || isTable || isBoard || isFile || isCustom) && (
          <NumberSetting
            label="Внутренний отступ"
            value={settings.padding}
            min={0}
            max={48}
            placeholder="По умолчанию"
            onChange={(value) => updateSetting("padding", value)}
          />
        )}

        {(isHeading || isText || isLatex || isCustom) && (
          <AlignSetting
            value={settings.textAlign}
            onChange={(value) => updateSetting("textAlign", value)}
          />
        )}

        {isCode && (
          <section className="border border-black bg-neutral-100 p-3">
            <h4 className="mb-3 font-bold">Настройки кода</h4>

            <label className="block">
              <span className="mb-1 block text-sm font-bold">Язык</span>
              <select
                value={settings.codeLanguage ?? "plain"}
                onChange={(event) =>
                  updateSetting("codeLanguage", event.target.value)
                }
                className="w-full border border-black bg-white px-3 py-2 outline-none"
              >
                {codeLanguages.map((language) => (
                  <option key={language} value={language}>
                    {language}
                  </option>
                ))}
              </select>
            </label>

            <label className="mt-3 flex items-center gap-2 border border-black bg-white px-3 py-2">
              <input
                type="checkbox"
                checked={Boolean(settings.codeWrap)}
                onChange={(event) =>
                  updateSetting("codeWrap", event.target.checked)
                }
              />
              <span className="text-sm">Переносить строки</span>
            </label>
          </section>
        )}

        <button
          type="button"
          onClick={resetSettings}
          className="w-full border border-black bg-white px-3 py-2 text-sm hover:bg-black hover:text-white"
        >
          Сбросить настройки блока
        </button>
      </div>
    </aside>
  );
}
