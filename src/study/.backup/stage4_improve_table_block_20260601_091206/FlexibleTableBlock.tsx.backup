import type {
  StudyNode,
  TableStudyBlock,
} from "../../types/study";
import { RichTextEditor, type RichTextActiveMarks, type RichTextCommand } from "./RichTextEditor";

interface FlexibleTableBlockProps {
  block: TableStudyBlock;
  nodes: StudyNode[];
  editable: boolean;
  formatCommand?: RichTextCommand | null;
  onChange: (block: TableStudyBlock) => void;
  onOpenNode: (nodeId: string) => void;
  onRichTextMarksChange?: (marks: RichTextActiveMarks) => void;
  onActiveRichTextEditorChange?: (editorId: string) => void;
}

function normalizeRows(rows: string[][]): string[][] {
  const maxColumns = Math.max(1, ...rows.map((row) => row.length));

  return rows.map((row) => [
    ...row,
    ...Array.from({ length: maxColumns - row.length }, () => ""),
  ]);
}

export function FlexibleTableBlock({
  block,
  nodes,
  editable,
  formatCommand,
  onChange,
  onOpenNode,
  onRichTextMarksChange,
  onActiveRichTextEditorChange,
}: FlexibleTableBlockProps) {
  const rows = normalizeRows(block.rows.length > 0 ? block.rows : [["", ""], ["", ""]]);
  const columnCount = Math.max(1, rows[0]?.length ?? 1);

  function getCellEditorId(rowIndex: number, columnIndex: number): string {
    return `${block.id}:cell:${rowIndex}:${columnIndex}`;
  }

  function updateCell(rowIndex: number, columnIndex: number, value: string) {
    const nextRows = rows.map((row, currentRowIndex) =>
      currentRowIndex === rowIndex
        ? row.map((cell, currentColumnIndex) =>
            currentColumnIndex === columnIndex ? value : cell
          )
        : row
    );

    onChange({
      ...block,
      rows: nextRows,
    });
  }

  function addRow() {
    onChange({
      ...block,
      rows: [...rows, Array.from({ length: columnCount }, () => "")],
    });
  }

  function addColumn() {
    onChange({
      ...block,
      rows: rows.map((row) => [...row, ""]),
    });
  }

  function removeRow(rowIndex: number) {
    if (rows.length <= 1) {
      return;
    }

    onChange({
      ...block,
      rows: rows.filter((_, index) => index !== rowIndex),
    });
  }

  function removeColumn(columnIndex: number) {
    if (columnCount <= 1) {
      return;
    }

    onChange({
      ...block,
      rows: rows.map((row) => row.filter((_, index) => index !== columnIndex)),
    });
  }

  function moveRow(rowIndex: number, direction: -1 | 1) {
    const targetIndex = rowIndex + direction;

    if (targetIndex < 0 || targetIndex >= rows.length) {
      return;
    }

    const nextRows = [...rows];
    const current = nextRows[rowIndex];

    nextRows[rowIndex] = nextRows[targetIndex];
    nextRows[targetIndex] = current;

    onChange({
      ...block,
      rows: nextRows,
    });
  }

  return (
    <div className="border border-black bg-white">
      {editable && (
        <div className="flex flex-wrap gap-2 border-b border-black bg-neutral-100 p-3">
          <button
            type="button"
            onClick={addRow}
            className="border border-black bg-white px-3 py-1 text-sm hover:bg-black hover:text-white"
          >
            + Row
          </button>

          <button
            type="button"
            onClick={addColumn}
            className="border border-black bg-white px-3 py-1 text-sm hover:bg-black hover:text-white"
          >
            + Column
          </button>

          <label className="flex items-center gap-2 border border-black bg-white px-3 py-1 text-sm">
            <input
              type="checkbox"
              checked={block.hasHeader}
              onChange={(event) =>
                onChange({
                  ...block,
                  hasHeader: event.target.checked,
                })
              }
            />
            Header
          </label>
        </div>
      )}

      <div className="overflow-auto">
        <table className="w-full border-collapse text-sm">
          <tbody>
            {rows.map((row, rowIndex) => {
              const isHeader = block.hasHeader && rowIndex === 0;

              return (
                <tr key={rowIndex} className={isHeader ? "bg-neutral-100 font-bold" : ""}>
                  {row.map((cell, columnIndex) => {
                    const CellTag = isHeader ? "th" : "td";

                    return (
                      <CellTag
                        key={columnIndex}
                        className="min-w-[160px] border border-black p-0 text-left align-top"
                      >
                        <div className="table-rich-cell">
                          <RichTextEditor
                            editorId={getCellEditorId(rowIndex, columnIndex)}
                            value={cell}
                            nodes={nodes}
                            editable={editable}
                            formatCommand={formatCommand}
                            onChange={(nextValue) =>
                              updateCell(rowIndex, columnIndex, nextValue)
                            }
                            onOpenNode={onOpenNode}
                            onActiveMarksChange={onRichTextMarksChange}
                            onActiveEditorChange={onActiveRichTextEditorChange}
                          />
                        </div>
                      </CellTag>
                    );
                  })}

                  {editable && (
                    <td className="w-[120px] border border-black bg-white p-1 align-top">
                      <div className="flex flex-col gap-1">
                        <button
                          type="button"
                          onClick={() => moveRow(rowIndex, -1)}
                          className="border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white"
                        >
                          Row Up
                        </button>

                        <button
                          type="button"
                          onClick={() => moveRow(rowIndex, 1)}
                          className="border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white"
                        >
                          Row Down
                        </button>

                        <button
                          type="button"
                          onClick={() => removeRow(rowIndex)}
                          className="border border-black bg-black px-2 py-1 text-xs text-white"
                        >
                          Delete Row
                        </button>
                      </div>
                    </td>
                  )}
                </tr>
              );
            })}

            {editable && (
              <tr>
                {Array.from({ length: columnCount }, (_, columnIndex) => (
                  <td key={columnIndex} className="border border-black p-1">
                    <button
                      type="button"
                      onClick={() => removeColumn(columnIndex)}
                      className="w-full border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white"
                    >
                      Delete Column {columnIndex + 1}
                    </button>
                  </td>
                ))}

                <td className="border border-black bg-neutral-100" />
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  );
}
