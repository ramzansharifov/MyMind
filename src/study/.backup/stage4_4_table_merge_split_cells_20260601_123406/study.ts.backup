export type StudyNodeType = "folder" | "material";

export type StudyBlockType =
  | "heading"
  | "text"
  | "latex"
  | "markdown"
  | "code"
  | "table"
  | "definition"
  | "problem"
  | "solution"
  | "board"
  | "file"
  | "divider"
  | "custom";

export type CustomFieldType =
  | "text"
  | "long_text"
  | "latex"
  | "number"
  | "checkbox"
  | "select"
  | "date"
  | "link";

export type CustomBlockValue = string | number | boolean;

export type BlockTextAlign = "left" | "center" | "right";
export type HeadingStyle = "h1" | "h2" | "h3";

export type TableCellTextAlign = "left" | "center" | "right";
export type TableCellVerticalAlign = "top" | "middle" | "bottom";

export interface TableCellStyle {
  backgroundColor?: string;
  textColor?: string;
  textAlign?: TableCellTextAlign;
  verticalAlign?: TableCellVerticalAlign;
}

export interface BlockSettings {
  headingStyle?: HeadingStyle;
  fontSize?: number;
  textColor?: string;
  backgroundColor?: string;
  padding?: number;
  textAlign?: BlockTextAlign;
  codeLanguage?: string;
  codeWrap?: boolean;
}

export interface CustomBlockField {
  id: string;
  label: string;
  type: CustomFieldType;
  required?: boolean;
  placeholder?: string;
  options?: string[];
}

export interface CustomBlockTemplate {
  id: string;
  name: string;
  icon: string;
  color?: string;
  description?: string;
  fields: CustomBlockField[];
  createdAt: string;
  updatedAt: string;
}

export interface StudyNode {
  id: string;
  type: StudyNodeType;
  title: string;
  parentId: string | null;
  order: number;
  createdAt: string;
  updatedAt: string;
}

export interface BoardPoint {
  x: number;
  y: number;
}

export interface BoardStroke {
  id: string;
  color?: string;

  points: BoardPoint[];
  width: number;
}

export interface StudyBlockBase<T extends StudyBlockType> {
  id: string;
  type: T;
  createdAt: string;
  updatedAt: string;
  settings?: BlockSettings;
  children?: StudyBlock[];
}

export interface ContentStudyBlock
  extends StudyBlockBase<
    | "heading"
    | "text"
    | "latex"
    | "markdown"
    | "code"
    | "definition"
    | "problem"
    | "solution"
  > {
  content: string;
}

export interface TableStudyBlock extends StudyBlockBase<"table"> {
  rows: string[][];
  hasHeader: boolean;
  columnWidths?: number[];
  cellStyles?: Record<string, TableCellStyle>;
}

export interface BoardStudyBlock extends StudyBlockBase<"board"> {
  title: string;
  strokes: BoardStroke[];
}

export interface FileStudyBlock extends StudyBlockBase<"file"> {
  fileId: string;
  fileName: string;
  note: string;
  mimeType: string;
  size: number;
}

export type DividerStudyBlock = StudyBlockBase<"divider">;

export interface CustomStudyBlock extends StudyBlockBase<"custom"> {
  templateId: string;
  values: Record<string, CustomBlockValue>;
}

export type StudyBlock =
  | ContentStudyBlock
  | TableStudyBlock
  | BoardStudyBlock
  | FileStudyBlock
  | DividerStudyBlock
  | CustomStudyBlock;

export interface StudyMaterial {
  id: string;
  nodeId: string;
  title: string;
  blocks: StudyBlock[];
  tags: string[];
  createdAt: string;
  updatedAt: string;
}

export interface StudyState {
  selectedNodeId: string | null;
  nodes: StudyNode[];
  materials: StudyMaterial[];
  customBlockTemplates: CustomBlockTemplate[];
}
