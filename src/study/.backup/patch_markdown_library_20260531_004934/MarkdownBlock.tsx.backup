import { useMemo, useState } from "react";

interface MarkdownBlockProps {
  value: string;
  editable: boolean;
  onChange: (value: string) => void;
}

function escapeHtml(value: string): string {
  return value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;");
}

function parseInlineMarkdown(value: string): string {
  return escapeHtml(value)
    .replace(/`([^`]+)`/g, "<code>$1</code>")
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
    .replace(/\*([^*]+)\*/g, "<em>$1</em>")
    .replace(/__([^_]+)__/g, "<strong>$1</strong>")
    .replace(/_([^_]+)_/g, "<em>$1</em>");
}

function markdownToHtml(markdown: string): string {
  const lines = markdown.split("\n");
  const html: string[] = [];
  let inUl = false;
  let inOl = false;
  let inCode = false;
  let codeLines: string[] = [];

  function closeLists() {
    if (inUl) {
      html.push("</ul>");
      inUl = false;
    }

    if (inOl) {
      html.push("</ol>");
      inOl = false;
    }
  }

  lines.forEach((line) => {
    if (line.trim().startsWith("```")) {
      if (inCode) {
        html.push(`<pre><code>${escapeHtml(codeLines.join("\n"))}</code></pre>`);
        codeLines = [];
        inCode = false;
      } else {
        closeLists();
        inCode = true;
      }

      return;
    }

    if (inCode) {
      codeLines.push(line);
      return;
    }

    const trimmed = line.trim();

    if (!trimmed) {
      closeLists();
      html.push("");
      return;
    }

    if (trimmed.startsWith("# ")) {
      closeLists();
      html.push(`<h1>${parseInlineMarkdown(trimmed.slice(2))}</h1>`);
      return;
    }

    if (trimmed.startsWith("## ")) {
      closeLists();
      html.push(`<h2>${parseInlineMarkdown(trimmed.slice(3))}</h2>`);
      return;
    }

    if (trimmed.startsWith("### ")) {
      closeLists();
      html.push(`<h3>${parseInlineMarkdown(trimmed.slice(4))}</h3>`);
      return;
    }

    if (trimmed.startsWith("> ")) {
      closeLists();
      html.push(`<blockquote>${parseInlineMarkdown(trimmed.slice(2))}</blockquote>`);
      return;
    }

    if (/^- /.test(trimmed)) {
      if (!inUl) {
        closeLists();
        html.push("<ul>");
        inUl = true;
      }

      html.push(`<li>${parseInlineMarkdown(trimmed.slice(2))}</li>`);
      return;
    }

    if (/^\d+\. /.test(trimmed)) {
      if (!inOl) {
        closeLists();
        html.push("<ol>");
        inOl = true;
      }

      html.push(`<li>${parseInlineMarkdown(trimmed.replace(/^\d+\. /, ""))}</li>`);
      return;
    }

    closeLists();
    html.push(`<p>${parseInlineMarkdown(trimmed)}</p>`);
  });

  if (inCode) {
    html.push(`<pre><code>${escapeHtml(codeLines.join("\n"))}</code></pre>`);
  }

  closeLists();

  return html.join("\n");
}

export function MarkdownBlock({
  value,
  editable,
  onChange,
}: MarkdownBlockProps) {
  const [preview, setPreview] = useState(!editable);

  const html = useMemo(() => markdownToHtml(value), [value]);

  if (!editable) {
    return (
      <div
        className="markdown-view"
        dangerouslySetInnerHTML={{ __html: html }}
      />
    );
  }

  return (
    <div className="border border-black bg-white">
      <div className="flex items-center justify-between border-b border-black bg-neutral-100 px-3 py-2">
        <span className="font-bold">Markdown</span>

        <button
          type="button"
          onClick={() => setPreview((previous) => !previous)}
          className="border border-black bg-white px-3 py-1 text-sm hover:bg-black hover:text-white"
        >
          {preview ? "Редактировать" : "Превью"}
        </button>
      </div>

      {preview ? (
        <div
          className="markdown-view p-3"
          dangerouslySetInnerHTML={{ __html: html }}
        />
      ) : (
        <textarea
          value={value}
          onChange={(event) => onChange(event.target.value)}
          rows={10}
          spellCheck={false}
          className="w-full border-0 bg-white px-3 py-2 font-mono text-sm outline-none"
          placeholder="# Markdown"
        />
      )}
    </div>
  );
}
