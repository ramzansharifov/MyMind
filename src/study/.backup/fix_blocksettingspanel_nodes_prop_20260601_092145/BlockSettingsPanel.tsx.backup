import { useEffect, useMemo, useState, type FormEvent } from "react";
import type {
  BlockSettings,
  BlockTextAlign,
  HeadingStyle,
  StudyBlock,
  StudyNode,
} from "../../types/study";
import { getBlockTitle } from "../../utils/blocks";
import {
  emitTableCommand,
  listenTableSelectionChanged,
  type TableCellSelection,
} from "../../utils/tableEvents";
import { CodeLanguageInput } from "./CodeLanguageInput";
import type {
  RichTextActiveMarks,
  RichTextCommandType,
} from "./RichTextEditor";

interface BlockSettingsPanelProps {
  block: StudyBlock | null;
  nodes: StudyNode[];
  richTextMarks?: RichTextActiveMarks;
  onRichTextCommand?: (command: RichTextCommandType, value?: string) => void;
  onChangeSettings: (settings: BlockSettings) => void;
}

function getSettings(block: StudyBlock | null): BlockSettings {
  return block?.settings ?? {};
}

function getToolButtonClass(active: boolean): string {
  return active
    ? "border border-black bg-black px-2 py-1 text-sm text-white"
    : "border border-black bg-white px-2 py-1 text-sm hover:bg-black hover:text-white";
}

function NumberSetting({
  label,
  value,
  min,
  max,
  placeholder,
  onChange,
}: {
  label: string;
  value: number | undefined;
  min: number;
  max: number;
  placeholder: string;
  onChange: (value: number | undefined) => void;
}) {
  return (
    <label className="block">
      <span className="mb-1 block text-sm font-bold">{label}</span>
      <input
        type="number"
        min={min}
        max={max}
        value={value ?? ""}
        placeholder={placeholder}
        onChange={(event) => {
          const rawValue = event.target.value;

          if (!rawValue) {
            onChange(undefined);
            return;
          }

          const nextValue = Math.min(max, Math.max(min, Number(rawValue)));
          onChange(nextValue);
        }}
        className="w-full border border-black bg-white px-3 py-2 outline-none"
      />
      <p className="mt-1 text-xs text-neutral-600">
        Диапазон: {min}–{max}
      </p>
    </label>
  );
}

function ColorSetting({
  label,
  value,
  defaultValue,
  onChange,
}: {
  label: string;
  value: string | undefined;
  defaultValue: string;
  onChange: (value: string | undefined) => void;
}) {
  return (
    <label className="block">
      <span className="mb-1 block text-sm font-bold">{label}</span>
      <div className="flex gap-2">
        <input
          type="color"
          value={value ?? defaultValue}
          onChange={(event) => onChange(event.target.value)}
          className="h-10 w-16 border border-black bg-white"
        />
        <button
          type="button"
          onClick={() => onChange(undefined)}
          className="flex-1 border border-black bg-white px-3 py-2 text-sm hover:bg-black hover:text-white"
        >
          Сбросить
        </button>
      </div>
    </label>
  );
}

function AlignSetting({
  value,
  onChange,
}: {
  value: BlockTextAlign | undefined;
  onChange: (value: BlockTextAlign | undefined) => void;
}) {
  return (
    <label className="block">
      <span className="mb-1 block text-sm font-bold">Выравнивание</span>
      <select
        value={value ?? "left"}
        onChange={(event) => onChange(event.target.value as BlockTextAlign)}
        className="w-full border border-black bg-white px-3 py-2 outline-none"
      >
        <option value="left">Слева</option>
        <option value="center">По центру</option>
        <option value="right">Справа</option>
      </select>
    </label>
  );
}

export function BlockSettingsPanel({
  block,
  nodes,
  richTextMarks,
  onRichTextCommand,
  onChangeSettings,
}: BlockSettingsPanelProps) {
  const [linkFormOpen, setLinkFormOpen] = useState(false);
  const [linkUrl, setLinkUrl] = useState("");
  const [internalLinkQuery, setInternalLinkQuery] = useState("");
  const [tableSelection, setTableSelection] = useState<TableCellSelection | null>(null);

  useEffect(() => {
    setLinkFormOpen(false);
    setLinkUrl("");
    setInternalLinkQuery("");
    setTableSelection(null);
  }, [block?.id]);

  useEffect(() => {
    return listenTableSelectionChanged((selection) => {
      if (!block || block.type !== "table") {
        setTableSelection(null);
        return;
      }

      if (selection?.blockId === block.id) {
        setTableSelection(selection);
      } else {
        setTableSelection(null);
      }
    });
  }, [block?.id, block?.type]);

  const materialNodes = useMemo(() => {
    const query = internalLinkQuery.trim().toLowerCase();

    return nodes
      .filter((node) => node.type === "material")
      .filter((node) => {
        if (!query) {
          return true;
        }

        return node.title.toLowerCase().includes(query);
      })
      .slice(0, 12);
  }, [nodes, internalLinkQuery]);

  if (!block) {
    return (
      <aside className="sticky top-[72px] max-h-[calc(100vh-84px)] overflow-auto border border-black bg-white p-4">
        <h3 className="font-bold">Настройки блока</h3>
        <p className="mt-3 text-sm text-neutral-600">
          Выбери блок слева. Если ничего не выбрано, новый блок из верхней панели добавится в конец материала.
        </p>
      </aside>
    );
  }

  const settings = getSettings(block);

  function updateSetting<K extends keyof BlockSettings>(
    key: K,
    value: BlockSettings[K]
  ) {
    onChangeSettings({
      ...settings,
      [key]: value,
    });
  }

  function resetSettings() {
    onChangeSettings({});
  }

  function runRichCommand(command: RichTextCommandType, value?: string) {
    onRichTextCommand?.(command, value);
  }

  function runTableCommand(type: Parameters<typeof emitTableCommand>[1], value?: number) {
    if (!block) {
      return;
    }

    emitTableCommand(block.id, type, value);
  }

  const isHeading = block.type === "heading";
  const isText = block.type === "text";
  const isLatex = block.type === "latex";
  const isMarkdown = block.type === "markdown";
  const isCode = block.type === "code";
  const isTable = block.type === "table";
  const isBoard = block.type === "board";
  const isFile = block.type === "file";
  const isCustom = block.type === "custom";

  const marks = richTextMarks ?? {
    bold: false,
    italic: false,
    underline: false,
    strikeThrough: false,
    unorderedList: false,
    orderedList: false,
    quote: false,
    link: false,
    linkHref: "",
    listStyle: "disc",
  };

  const showRichTools = isText || isTable;
  const hasSelectedTableCell = Boolean(isTable && tableSelection);

  function openLinkForm() {
    setLinkUrl(marks.linkHref || "");
    setLinkFormOpen(true);
  }

  function closeLinkForm() {
    setLinkFormOpen(false);
    setLinkUrl("");
  }

  function submitLinkForm(event: FormEvent<HTMLFormElement>) {
    event.preventDefault();

    const trimmedUrl = linkUrl.trim();

    if (!trimmedUrl) {
      return;
    }

    runRichCommand("link", trimmedUrl);
    closeLinkForm();
  }

  function insertInternalLink(title: string) {
    runRichCommand("internalLink", title);
    setInternalLinkQuery("");
  }

  return (
    <aside className="sticky top-[72px] max-h-[calc(100vh-84px)] overflow-auto border border-black bg-white">
      <div className="border-b border-black bg-neutral-100 px-4 py-3">
        <h3 className="font-bold">Настройки блока</h3>
        <p className="mt-1 text-sm text-neutral-600">
          {getBlockTitle(block)}
        </p>
      </div>

      <div className="space-y-4 p-4">
        <section className="border border-black bg-neutral-100 p-3 text-xs text-neutral-700">
          Новый блок из верхней панели будет добавлен внутрь выбранного блока.
          Чтобы добавить блок в конец материала, сними выделение с блока.
        </section>

        {isTable && (
          <section className="border border-black bg-white p-3">
            <h4 className="mb-3 font-bold">Таблица</h4>

            <p className="mb-3 text-xs text-neutral-600">
              {tableSelection
                ? `Активная ячейка: строка ${tableSelection.rowIndex + 1}, колонка ${tableSelection.columnIndex + 1}`
                : "Кликни по ячейке таблицы, чтобы включить действия рядом с ней."}
            </p>

            <div className="flex flex-wrap gap-2">
              <button
                type="button"
                onClick={() => runTableCommand("toggleHeader")}
                className={getToolButtonClass(block.type === "table" && block.hasHeader)}
              >
                Header
              </button>

              <button
                type="button"
                onClick={() => runTableCommand("exportCsv")}
                className={getToolButtonClass(false)}
              >
                Export CSV
              </button>
            </div>

            <div className="my-3 border-t border-black" />

            <div className="grid grid-cols-2 gap-2">
              <button type="button" disabled={!hasSelectedTableCell} onClick={() => runTableCommand("addRowAbove")} className="border border-black bg-white px-2 py-1 text-sm hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400">
                Row above
              </button>

              <button type="button" disabled={!hasSelectedTableCell} onClick={() => runTableCommand("addRowBelow")} className="border border-black bg-white px-2 py-1 text-sm hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400">
                Row below
              </button>

              <button type="button" disabled={!hasSelectedTableCell} onClick={() => runTableCommand("deleteRow")} className="border border-black bg-white px-2 py-1 text-sm hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400">
                Delete row
              </button>

              <button type="button" disabled={!hasSelectedTableCell} onClick={() => runTableCommand("moveRowUp")} className="border border-black bg-white px-2 py-1 text-sm hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400">
                Row up
              </button>

              <button type="button" disabled={!hasSelectedTableCell} onClick={() => runTableCommand("moveRowDown")} className="border border-black bg-white px-2 py-1 text-sm hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400">
                Row down
              </button>
            </div>

            <div className="my-3 border-t border-black" />

            <div className="grid grid-cols-2 gap-2">
              <button type="button" disabled={!hasSelectedTableCell} onClick={() => runTableCommand("addColumnLeft")} className="border border-black bg-white px-2 py-1 text-sm hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400">
                Column left
              </button>

              <button type="button" disabled={!hasSelectedTableCell} onClick={() => runTableCommand("addColumnRight")} className="border border-black bg-white px-2 py-1 text-sm hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400">
                Column right
              </button>

              <button type="button" disabled={!hasSelectedTableCell} onClick={() => runTableCommand("deleteColumn")} className="col-span-2 border border-black bg-white px-2 py-1 text-sm hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400">
                Delete column
              </button>
            </div>

            {tableSelection && (
              <label className="mt-3 block border-t border-black pt-3">
                <span className="mb-2 block text-sm font-bold">
                  Ширина колонки {tableSelection.columnIndex + 1}
                </span>

                <input
                  type="range"
                  min={80}
                  max={600}
                  value={tableSelection.columnWidth}
                  onChange={(event) =>
                    runTableCommand("setColumnWidth", Number(event.target.value))
                  }
                  className="w-full"
                />

                <div className="mt-2 flex items-center gap-2">
                  <input
                    type="number"
                    min={80}
                    max={600}
                    value={tableSelection.columnWidth}
                    onChange={(event) =>
                      runTableCommand("setColumnWidth", Number(event.target.value))
                    }
                    className="w-24 border border-black bg-white px-2 py-1 outline-none"
                  />

                  <span className="text-sm">px</span>
                </div>
              </label>
            )}
          </section>
        )}

        {showRichTools && (
          <section className="border border-black bg-white p-3">
            <h4 className="mb-3 font-bold">
              {isTable ? "Форматирование текста в ячейках" : "Форматирование текста"}
            </h4>

            <p className="mb-3 text-xs text-neutral-600">
              {isTable
                ? "Поставь курсор в ячейку таблицы или выдели часть текста в ячейке, затем нажми нужное действие."
                : "Выдели часть текста внутри блока и нажми нужное действие здесь."}
            </p>

            <div className="flex flex-wrap gap-1">
              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("paragraph")} className={getToolButtonClass(false)}>P</button>
              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("bold")} className={getToolButtonClass(marks.bold)}><span className="font-bold">B</span></button>
              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("italic")} className={getToolButtonClass(marks.italic)}><span className="italic">I</span></button>
              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("underline")} className={getToolButtonClass(marks.underline)}><span className="underline">U</span></button>
              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("strikeThrough")} className={getToolButtonClass(marks.strikeThrough)}><span className="line-through">S</span></button>
              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("quote")} className={getToolButtonClass(marks.quote)}>Quote</button>
              <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("clearFormat")} className={getToolButtonClass(false)}>Clear</button>
            </div>

            <div className="my-3 border-t border-black" />

            <div>
              <h5 className="mb-2 font-bold">Списки</h5>

              <div className="grid grid-cols-4 gap-2">
                <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("unorderedList", "disc")} className={getToolButtonClass(marks.unorderedList && marks.listStyle === "disc")} title="Маркированный список">•</button>
                <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("orderedList", "decimal")} className={getToolButtonClass(marks.orderedList && marks.listStyle === "decimal")} title="Нумерованный список 1.">1.</button>
                <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("orderedList", "decimal-parenthesis")} className={getToolButtonClass(marks.orderedList && marks.listStyle === "decimal-parenthesis")} title="Нумерованный список 1)">1)</button>
                <button type="button" onMouseDown={(event) => event.preventDefault()} onClick={() => runRichCommand("unorderedList", "checkbox-list")} className={getToolButtonClass(marks.unorderedList && marks.listStyle === "checkbox-list")} title="Checklist / задачи">☐</button>
              </div>
            </div>

            <div className="mt-4 border-t border-black pt-3">
              <h5 className="mb-2 font-bold">Внутренняя ссылка</h5>

              <input
                value={internalLinkQuery}
                onMouseDown={(event) => event.stopPropagation()}
                onChange={(event) => setInternalLinkQuery(event.target.value)}
                placeholder="Найти материал..."
                className="w-full border border-black bg-white px-3 py-2 text-sm outline-none"
              />

              <div className="mt-2 max-h-44 overflow-auto border border-black">
                {materialNodes.length > 0 ? (
                  materialNodes.map((node) => (
                    <button
                      key={node.id}
                      type="button"
                      onMouseDown={(event) => event.preventDefault()}
                      onClick={() => insertInternalLink(node.title)}
                      className="block w-full border-b border-neutral-300 bg-white px-2 py-2 text-left text-xs hover:bg-black hover:text-white"
                    >
                      [[{node.title}]]
                    </button>
                  ))
                ) : (
                  <div className="px-2 py-2 text-xs text-neutral-600">
                    Материалы не найдены.
                  </div>
                )}
              </div>

              <p className="mt-2 text-xs text-neutral-600">
                Ссылка вставится в активное место текста или выбранной ячейки.
              </p>
            </div>

            <div className="mt-4 border-t border-black pt-3">
              <h5 className="mb-2 font-bold">Интернет-ссылка</h5>

              {marks.link && (
                <p className="mb-2 break-all border border-black bg-neutral-100 px-2 py-1 text-xs">
                  Текущая ссылка: {marks.linkHref || "без href"}
                </p>
              )}

              <div className="grid grid-cols-2 gap-2">
                <button
                  type="button"
                  onMouseDown={(event) => event.preventDefault()}
                  onClick={openLinkForm}
                  className={getToolButtonClass(marks.link)}
                >
                  {marks.link ? "Edit link" : "Add link"}
                </button>

                <button
                  type="button"
                  onMouseDown={(event) => event.preventDefault()}
                  onClick={() => {
                    runRichCommand("unlink");
                    closeLinkForm();
                  }}
                  className={getToolButtonClass(false)}
                >
                  Unlink
                </button>
              </div>

              {linkFormOpen && (
                <form
                  onSubmit={submitLinkForm}
                  onMouseDown={(event) => event.stopPropagation()}
                  className="mt-3 border border-black bg-neutral-100 p-3"
                >
                  <label className="block">
                    <span className="mb-1 block text-xs font-bold">
                      URL ссылки
                    </span>

                    <input
                      value={linkUrl}
                      onChange={(event) => setLinkUrl(event.target.value)}
                      placeholder="https://example.com"
                      className="w-full border border-black bg-white px-3 py-2 text-sm outline-none"
                    />
                  </label>

                  <p className="mt-2 text-xs text-neutral-600">
                    Если текст выделен, ссылка будет применена к выделенному тексту. Если курсор стоит внутри существующей ссылки, URL будет обновлён.
                  </p>

                  <div className="mt-3 grid grid-cols-2 gap-2">
                    <button type="submit" className="border border-black bg-black px-3 py-2 text-sm text-white">Save</button>
                    <button type="button" onClick={closeLinkForm} className="border border-black bg-white px-3 py-2 text-sm hover:bg-black hover:text-white">Cancel</button>
                  </div>
                </form>
              )}
            </div>
          </section>
        )}

        {isHeading && (
          <section className="border border-black bg-white p-3">
            <h4 className="mb-3 font-bold">Стиль заголовка</h4>

            <label className="block">
              <span className="mb-1 block text-sm font-bold">Тип заголовка</span>
              <select
                value={settings.headingStyle ?? "h1"}
                onChange={(event) =>
                  updateSetting("headingStyle", event.target.value as HeadingStyle)
                }
                className="w-full border border-black bg-white px-3 py-2 outline-none"
              >
                <option value="h1">H1 — главный заголовок</option>
                <option value="h2">H2 — раздел</option>
                <option value="h3">H3 — подпункт</option>
              </select>
            </label>
          </section>
        )}

        {(isHeading || isText || isLatex || isMarkdown || isCode) && (
          <NumberSetting
            label={
              isHeading
                ? "Размер заголовка"
                : isCode
                  ? "Размер кода"
                  : isLatex
                    ? "Размер LaTeX"
                    : isMarkdown
                      ? "Размер Markdown"
                      : "Размер текста"
            }
            value={settings.fontSize}
            min={isHeading ? 18 : isCode ? 11 : 12}
            max={isHeading ? 42 : isCode ? 22 : isLatex ? 34 : 28}
            placeholder={
              isHeading
                ? "Авто по H1/H2/H3"
                : isText
                  ? "16"
                  : isLatex
                    ? "20"
                    : isMarkdown
                      ? "16"
                      : "14"
            }
            onChange={(value) => updateSetting("fontSize", value)}
          />
        )}

        {(isHeading || isText || isLatex || isMarkdown || isCode || isCustom) && (
          <ColorSetting
            label="Цвет текста"
            value={settings.textColor}
            defaultValue="#000000"
            onChange={(value) => updateSetting("textColor", value)}
          />
        )}

        <ColorSetting
          label="Цвет фона блока"
          value={settings.backgroundColor}
          defaultValue="#ffffff"
          onChange={(value) => updateSetting("backgroundColor", value)}
        />

        {(isHeading || isText || isLatex || isMarkdown || isCode || isTable || isBoard || isFile || isCustom) && (
          <NumberSetting
            label="Внутренний отступ"
            value={settings.padding}
            min={0}
            max={48}
            placeholder="По умолчанию"
            onChange={(value) => updateSetting("padding", value)}
          />
        )}

        {(isHeading || isText || isLatex || isMarkdown || isCustom) && (
          <AlignSetting
            value={settings.textAlign}
            onChange={(value) => updateSetting("textAlign", value)}
          />
        )}

        {isCode && (
          <section className="border border-black bg-neutral-100 p-3">
            <h4 className="mb-3 font-bold">Настройки кода</h4>

            <CodeLanguageInput
              value={settings.codeLanguage}
              onChange={(value) => updateSetting("codeLanguage", value)}
            />

            <label className="mt-3 flex items-center gap-2 border border-black bg-white px-3 py-2">
              <input
                type="checkbox"
                checked={Boolean(settings.codeWrap)}
                onChange={(event) =>
                  updateSetting("codeWrap", event.target.checked)
                }
              />
              <span className="text-sm">Переносить строки</span>
            </label>
          </section>
        )}

        <button
          type="button"
          onClick={resetSettings}
          className="w-full border border-black bg-white px-3 py-2 text-sm hover:bg-black hover:text-white"
        >
          Сбросить настройки блока
        </button>
      </div>
    </aside>
  );
}
