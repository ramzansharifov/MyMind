import type {
  BoardStudyBlock,
  ContentStudyBlock,
  CustomBlockTemplate,
  CustomBlockValue,
  CustomStudyBlock,
  FileStudyBlock,
  StudyBlock,
  StudyBlockType,
  TableStudyBlock,
} from "../types/study";
import { createId, now } from "./ids";

export type SystemBlockType = Exclude<StudyBlockType, "custom">;

export function isContentBlock(block: StudyBlock): block is ContentStudyBlock {
  return (
    block.type === "heading" ||
    block.type === "text" ||
    block.type === "latex" ||
    block.type === "markdown" ||
    block.type === "code" ||
    block.type === "definition" ||
    block.type === "problem" ||
    block.type === "solution"
  );
}

export function isTableBlock(block: StudyBlock): block is TableStudyBlock {
  return block.type === "table";
}

export function isBoardBlock(block: StudyBlock): block is BoardStudyBlock {
  return block.type === "board";
}

export function isFileBlock(block: StudyBlock): block is FileStudyBlock {
  return block.type === "file";
}

export function isCustomBlock(block: StudyBlock): block is CustomStudyBlock {
  return block.type === "custom";
}

export function getBlockTitle(
  block: StudyBlock,
  templates: CustomBlockTemplate[] = []
): string {
  if (block.type === "heading") return "Заголовок";
  if (block.type === "text") return "Текст";
  if (block.type === "latex") return "LaTeX";
  if (block.type === "markdown") return "Markdown";
  if (block.type === "code") return "Код";
  if (block.type === "table") return "Таблица";
  if (block.type === "definition") return "Определение";
  if (block.type === "problem") return "Задача";
  if (block.type === "solution") return "Решение";
  if (block.type === "board") return "Доска";
  if (block.type === "file") return "Файл";
  if (block.type === "divider") return "Разделитель";

  if (block.type === "custom") {
    return templates.find((template) => template.id === block.templateId)?.name ?? "Кастомный блок";
  }

  return "Блок";
}

function getChildrenText(
  block: StudyBlock,
  templates: CustomBlockTemplate[] = []
): string {
  return (block.children ?? [])
    .map((child) => getBlockText(child, templates))
    .filter(Boolean)
    .join(" ");
}

export function getBlockText(
  block: StudyBlock,
  templates: CustomBlockTemplate[] = []
): string {
  if (isContentBlock(block)) {
    return [block.content, getChildrenText(block, templates)].filter(Boolean).join(" ");
  }

  if (isTableBlock(block)) {
    const tableText = block.rows
      .flatMap((row) => row)
      .filter(Boolean)
      .join(" ");

    return [tableText, getChildrenText(block, templates)].filter(Boolean).join(" ");
  }

  if (isBoardBlock(block)) {
    return [block.title, getChildrenText(block, templates)].filter(Boolean).join(" ");
  }

  if (isFileBlock(block)) {
    return [`${block.fileName} ${block.note}`, getChildrenText(block, templates)].filter(Boolean).join(" ");
  }

  if (isCustomBlock(block)) {
    const template = templates.find((item) => item.id === block.templateId);

    return [
      template?.name ?? "Custom block",
      ...Object.values(block.values).map(String),
      getChildrenText(block, templates),
    ].filter(Boolean).join(" ");
  }

  return getChildrenText(block, templates);
}

export function getDefaultCustomValue(type: string): CustomBlockValue {
  if (type === "checkbox") {
    return false;
  }

  if (type === "number") {
    return 0;
  }

  return "";
}

export function createBlock(type: SystemBlockType): StudyBlock {
  const base = {
    id: createId("block"),
    createdAt: now(),
    updatedAt: now(),
    children: [],
  };

  if (type === "table") {
    return {
      ...base,
      type,
      hasHeader: true,
      rows: [
        ["Заголовок 1", "Заголовок 2", "Заголовок 3"],
        ["", "", ""],
        ["", "", ""],
      ],
    };
  }

  if (type === "board") {
    return {
      ...base,
      type,
      title: "Новая доска",
      strokes: [],
    };
  }

  if (type === "file") {
    return {
      ...base,
      type,
      fileId: "",
      fileName: "",
      note: "",
      mimeType: "",
      size: 0,
      dataUrl: "",
    };
  }

  if (type === "divider") {
    return {
      ...base,
      type,
    };
  }

  const contentByType: Record<string, string> = {
    heading: "Новый заголовок",
    text: "",
    latex: "v = \\frac{s}{t}",
    markdown: "# Заголовок\n\nОбычный текст с **жирным**, *курсивом* и списком:\n\n- пункт 1\n- пункт 2",
    code: "function example() {\n  console.log(\"Hello\");\n}",
    definition: "",
    problem: "",
    solution: "",
  };

  const defaultSettings =
    type === "code"
      ? {
          fontSize: 14,
          backgroundColor: "#f5f5f5",
          textColor: "#000000",
          padding: 12,
          codeLanguage: "javascript",
          codeWrap: true,
        }
      : undefined;

  return {
    ...base,
    type,
    content: contentByType[type],
    settings: defaultSettings,
  } as ContentStudyBlock;
}

export function createCustomBlock(template: CustomBlockTemplate): CustomStudyBlock {
  const values: Record<string, CustomBlockValue> = {};

  template.fields.forEach((field) => {
    values[field.id] = getDefaultCustomValue(field.type);
  });

  return {
    id: createId("block"),
    type: "custom",
    templateId: template.id,
    values,
    children: [],
    createdAt: now(),
    updatedAt: now(),
  };
}

export function cloneBlock(block: StudyBlock): StudyBlock {
  const copy = JSON.parse(JSON.stringify(block)) as StudyBlock;

  function renewIds(item: StudyBlock): StudyBlock {
    return {
      ...item,
      id: createId("block"),
      createdAt: now(),
      updatedAt: now(),
      children: (item.children ?? []).map(renewIds),
    };
  }

  return renewIds(copy);
}
