import { useEffect, useRef, useState } from "react";
import type { FileStudyBlock } from "../../types/study";
import {
  deleteFileFromStore,
  getFileFromStore,
  saveFileToStore,
} from "../../utils/fileStore";

interface FileBlockProps {
  block: FileStudyBlock;
  editable: boolean;
  onChange: (block: FileStudyBlock) => void;
}

const MAX_FILE_SIZE_MB = 50;
const MAX_FILE_SIZE_BYTES = MAX_FILE_SIZE_MB * 1024 * 1024;

type PreviewKind = "image" | "video" | "audio" | "pdf" | "unknown";

function formatFileSize(size: number): string {
  if (!size) {
    return "0 B";
  }

  if (size < 1024) {
    return `${size} B`;
  }

  if (size < 1024 * 1024) {
    return `${(size / 1024).toFixed(1)} KB`;
  }

  return `${(size / 1024 / 1024).toFixed(1)} MB`;
}

function getFileExtension(fileName: string): string {
  const parts = fileName.toLowerCase().split(".");

  return parts.length > 1 ? parts[parts.length - 1] : "";
}

function getPreviewKind(block: FileStudyBlock): PreviewKind {
  const mimeType = (block.mimeType || "").toLowerCase();
  const extension = getFileExtension(block.fileName || "");

  if (mimeType.startsWith("image/")) {
    return "image";
  }

  if (mimeType.startsWith("video/")) {
    return "video";
  }

  if (mimeType.startsWith("audio/")) {
    return "audio";
  }

  if (mimeType === "application/pdf" || extension === "pdf") {
    return "pdf";
  }

  if (["jpg", "jpeg", "png", "gif", "webp", "svg"].includes(extension)) {
    return "image";
  }

  if (["mp4", "webm", "ogg", "mov", "mkv"].includes(extension)) {
    return "video";
  }

  if (["mp3", "wav", "ogg", "m4a", "aac", "flac"].includes(extension)) {
    return "audio";
  }

  return "unknown";
}

function openFileInNewTab(url: string) {
  if (!url) {
    return;
  }

  const opened = window.open(url, "_blank");

  if (!opened) {
    window.alert("Браузер заблокировал открытие файла в новой вкладке.");
  }
}

function downloadFile(block: FileStudyBlock, url: string) {
  if (!url || !block.fileName) {
    return;
  }

  const link = document.createElement("a");
  link.href = url;
  link.download = block.fileName;
  link.click();
}

function MediaPreview({
  block,
  previewUrl,
  loading,
  error,
}: {
  block: FileStudyBlock;
  previewUrl: string;
  loading: boolean;
  error: string;
}) {
  const previewKind = getPreviewKind(block);

  if (loading) {
    return (
      <div className="border border-dashed border-black bg-white px-3 py-4 text-sm text-neutral-600">
        Загрузка файла из локального хранилища...
      </div>
    );
  }

  if (error) {
    return (
      <div className="border border-black bg-white p-3 text-sm">
        <p className="font-bold">Файл не найден в локальном хранилище</p>
        <p className="mt-1 text-neutral-700">{error}</p>
      </div>
    );
  }

  if (!previewUrl) {
    return (
      <div className="border border-dashed border-black bg-white px-3 py-4 text-sm text-neutral-600">
        Файл не выбран.
      </div>
    );
  }

  if (previewKind === "image") {
    return (
      <div className="border border-black bg-white p-2">
        <img
          src={previewUrl}
          alt={block.fileName || "Uploaded image"}
          className="max-h-[520px] w-full object-contain"
        />
      </div>
    );
  }

  if (previewKind === "video") {
    return (
      <div className="border border-black bg-white p-2">
        <video
          src={previewUrl}
          controls
          className="max-h-[520px] w-full bg-black"
        >
          Твой браузер не поддерживает просмотр видео.
        </video>
      </div>
    );
  }

  if (previewKind === "audio") {
    return (
      <div className="border border-black bg-white p-3">
        <audio
          src={previewUrl}
          controls
          className="w-full"
        >
          Твой браузер не поддерживает аудио.
        </audio>
      </div>
    );
  }

  if (previewKind === "pdf") {
    return (
      <div className="border border-black bg-white">
        <iframe
          src={previewUrl}
          title={block.fileName || "PDF preview"}
          className="h-[520px] w-full border-0"
        />
      </div>
    );
  }

  return (
    <div className="border border-black bg-white p-3 text-sm">
      <p className="font-bold">Предпросмотр недоступен</p>
      <p className="mt-1 break-all text-neutral-700">
        {block.fileName || "Файл без названия"}
      </p>

      <div className="mt-3 flex flex-wrap gap-2">
        <button
          type="button"
          onClick={() => openFileInNewTab(previewUrl)}
          className="border border-black bg-white px-3 py-2 text-sm hover:bg-black hover:text-white"
        >
          Открыть
        </button>

        <button
          type="button"
          onClick={() => downloadFile(block, previewUrl)}
          className="border border-black bg-black px-3 py-2 text-sm text-white"
        >
          Скачать
        </button>
      </div>
    </div>
  );
}

export function FileBlock({
  block,
  editable,
  onChange,
}: FileBlockProps) {
  const [infoOpen, setInfoOpen] = useState(false);
  const [previewUrl, setPreviewUrl] = useState("");
  const [loadingFile, setLoadingFile] = useState(false);
  const [fileError, setFileError] = useState("");
  const objectUrlRef = useRef<string | null>(null);

  const hasFile = Boolean(block.fileId || block.dataUrl);

  useEffect(() => {
    let cancelled = false;

    function revokePreviousObjectUrl() {
      if (objectUrlRef.current) {
        URL.revokeObjectURL(objectUrlRef.current);
        objectUrlRef.current = null;
      }
    }

    async function loadStoredFile() {
      revokePreviousObjectUrl();
      setPreviewUrl("");
      setFileError("");

      if (!block.fileId) {
        setPreviewUrl(block.dataUrl || "");
        setLoadingFile(false);
        return;
      }

      setLoadingFile(true);

      try {
        const storedFile = await getFileFromStore(block.fileId);

        if (cancelled) {
          return;
        }

        if (!storedFile) {
          if (block.dataUrl) {
            setPreviewUrl(block.dataUrl);
          } else {
            setFileError("В JSON есть fileId, но сам файл не найден в IndexedDB этого браузера.");
          }

          return;
        }

        const objectUrl = URL.createObjectURL(storedFile.blob);
        objectUrlRef.current = objectUrl;
        setPreviewUrl(objectUrl);
      } catch (error) {
        console.error(error);

        if (!cancelled) {
          setFileError("Не удалось загрузить файл из IndexedDB.");
        }
      } finally {
        if (!cancelled) {
          setLoadingFile(false);
        }
      }
    }

    loadStoredFile();

    return () => {
      cancelled = true;
      revokePreviousObjectUrl();
    };
  }, [block.fileId, block.dataUrl]);

  async function handleFileChange(file: File | undefined) {
    if (!file) {
      return;
    }

    if (file.size > MAX_FILE_SIZE_BYTES) {
      window.alert(`Файл слишком большой. Максимальный размер: ${MAX_FILE_SIZE_MB} MB.`);
      return;
    }

    try {
      if (block.fileId) {
        await deleteFileFromStore(block.fileId);
      }

      const storedFile = await saveFileToStore(file);

      onChange({
        ...block,
        fileId: storedFile.id,
        fileName: storedFile.fileName,
        mimeType: storedFile.mimeType,
        size: storedFile.size,
        dataUrl: "",
      });

      setInfoOpen(false);
    } catch (error) {
      console.error(error);
      window.alert("Не удалось сохранить файл в локальное хранилище.");
    }
  }

  async function removeFile() {
    try {
      if (block.fileId) {
        await deleteFileFromStore(block.fileId);
      }
    } catch (error) {
      console.error(error);
    }

    onChange({
      ...block,
      fileId: "",
      fileName: "",
      mimeType: "",
      size: 0,
      dataUrl: "",
    });

    setInfoOpen(false);
  }

  return (
    <div className="border border-black bg-white">
      <div className="flex items-center justify-between border-b border-black bg-neutral-100 px-3 py-2">
        <span className="font-bold">Файл</span>

        <button
          type="button"
          onClick={() => setInfoOpen((previous) => !previous)}
          disabled={!hasFile}
          className={
            hasFile
              ? "border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white"
              : "border border-neutral-400 bg-neutral-100 px-2 py-1 text-xs text-neutral-400"
          }
          title="Информация о файле"
        >
          Info
        </button>
      </div>

      <div className="space-y-3 p-3">
        {editable && (
          <label className="block">
            <span className="mb-1 block text-sm font-bold">Выбрать файл</span>

            <input
              type="file"
              onChange={(event) => handleFileChange(event.target.files?.[0])}
              className="w-full border border-black bg-white px-3 py-2 text-sm"
            />

            <p className="mt-1 text-xs text-neutral-600">
              Максимальный размер: {MAX_FILE_SIZE_MB} MB. Новый файл сохраняется отдельно в IndexedDB, а не внутри JSON.
            </p>
          </label>
        )}

        <label className="block">
          <span className="mb-1 block text-sm font-bold">Комментарий</span>

          {editable ? (
            <textarea
              value={block.note}
              onChange={(event) =>
                onChange({
                  ...block,
                  note: event.target.value,
                })
              }
              rows={3}
              placeholder="Комментарий к файлу"
              className="w-full border border-black bg-white px-3 py-2 text-sm outline-none"
            />
          ) : (
            block.note && (
              <div className="whitespace-pre-wrap border border-black bg-white px-3 py-2 text-sm">
                {block.note}
              </div>
            )
          )}
        </label>

        <MediaPreview
          block={block}
          previewUrl={previewUrl}
          loading={loadingFile}
          error={fileError}
        />

        {infoOpen && hasFile && (
          <div className="border border-black bg-neutral-100 p-3 text-sm">
            <div className="mb-3 flex items-center justify-between gap-3">
              <span className="font-bold">Информация о файле</span>

              <button
                type="button"
                onClick={() => setInfoOpen(false)}
                className="border border-black bg-white px-2 py-1 text-xs hover:bg-black hover:text-white"
              >
                Close
              </button>
            </div>

            <dl className="grid grid-cols-[90px_1fr] gap-x-3 gap-y-2">
              <dt className="font-bold">Название</dt>
              <dd className="break-all">{block.fileName}</dd>

              <dt className="font-bold">Тип</dt>
              <dd>{block.mimeType || "unknown"}</dd>

              <dt className="font-bold">Размер</dt>
              <dd>{formatFileSize(block.size)}</dd>

              <dt className="font-bold">Хранилище</dt>
              <dd>{block.fileId ? "IndexedDB" : "Legacy dataUrl in JSON"}</dd>
            </dl>

            <div className="mt-4 flex flex-wrap gap-2">
              <button
                type="button"
                onClick={() => downloadFile(block, previewUrl || block.dataUrl)}
                disabled={!previewUrl && !block.dataUrl}
                className="border border-black bg-black px-3 py-2 text-sm text-white disabled:border-neutral-400 disabled:bg-neutral-200 disabled:text-neutral-500"
              >
                Скачать
              </button>

              <button
                type="button"
                onClick={() => openFileInNewTab(previewUrl || block.dataUrl)}
                disabled={!previewUrl && !block.dataUrl}
                className="border border-black bg-white px-3 py-2 text-sm hover:bg-black hover:text-white disabled:border-neutral-400 disabled:bg-neutral-100 disabled:text-neutral-400"
              >
                Открыть
              </button>

              {editable && (
                <button
                  type="button"
                  onClick={removeFile}
                  className="border border-black bg-white px-3 py-2 text-sm hover:bg-black hover:text-white"
                >
                  Удалить файл
                </button>
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
