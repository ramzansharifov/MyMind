import type { CustomBlockTemplate, StudyBlock } from "../../types/study";
import {
  createBlock,
  createCustomBlock,
  type SystemBlockType,
} from "../../utils/blocks";

interface AddBlockBarProps {
  templates: CustomBlockTemplate[];
  onAddBlock: (block: StudyBlock) => void;
  onManageTemplates: () => void;
}

const systemBlocks: Array<{
  type: SystemBlockType;
  label: string;
}> = [
  { type: "heading", label: "Заголовок" },
  { type: "text", label: "Текст" },
  { type: "latex", label: "LaTeX" },
  { type: "code", label: "Код" },
  { type: "board", label: "Доска" },
  { type: "file", label: "Файл" },
  { type: "divider", label: "Линия" },
];

export function AddBlockBar({
  templates,
  onAddBlock,
  onManageTemplates,
}: AddBlockBarProps) {
  return (
    <div className="mt-4 border border-black bg-white p-3">
      <div className="flex flex-wrap gap-2">
        {systemBlocks.map((block) => (
          <button
            key={block.type}
            type="button"
            className="border border-black bg-white px-3 py-2 text-sm hover:bg-black hover:text-white"
            onClick={() => onAddBlock(createBlock(block.type))}
          >
            + {block.label}
          </button>
        ))}

        {templates.map((template) => (
          <button
            key={template.id}
            type="button"
            className="border border-black bg-white px-3 py-2 text-sm hover:bg-black hover:text-white"
            onClick={() => onAddBlock(createCustomBlock(template))}
          >
            + [{template.icon || "B"}] {template.name}
          </button>
        ))}

        <button
          type="button"
          onClick={onManageTemplates}
          className="ml-auto border border-black bg-black px-3 py-2 text-sm text-white"
        >
          Шаблоны
        </button>
      </div>
    </div>
  );
}
