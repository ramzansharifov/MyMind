import type {
  TableCellSpan,
  TableCellStyle,
} from "../types/study";

export interface TableCellSelection {
  blockId: string;
  rowIndex: number;
  columnIndex: number;
  rowCount: number;
  columnCount: number;
  columnWidth: number;
  cellStyle?: TableCellStyle;
  cellSpan?: TableCellSpan;
}

export type TableCommandType =
  | "addRowAbove"
  | "addRowBelow"
  | "deleteRow"
  | "addColumnLeft"
  | "addColumnRight"
  | "deleteColumn"
  | "moveRowUp"
  | "moveRowDown"
  | "setColumnWidth"
  | "toggleHeader"
  | "exportCsv"
  | "setCellBackgroundColor"
  | "setCellTextColor"
  | "setCellTextAlign"
  | "setCellVerticalAlign"
  | "clearCellStyle"
  | "mergeCellRight"
  | "mergeCellDown"
  | "splitCell";

export interface TableCommand {
  blockId: string;
  type: TableCommandType;
  value?: number | string;
}

const TABLE_COMMAND_EVENT = "mymind-table-command";
const TABLE_SELECTION_EVENT = "mymind-table-selection";

export function emitTableCommand(
  blockId: string,
  type: TableCommandType,
  value?: number | string
): void {
  window.dispatchEvent(
    new CustomEvent<TableCommand>(TABLE_COMMAND_EVENT, {
      detail: {
        blockId,
        type,
        value,
      },
    })
  );
}

export function listenTableCommand(
  blockId: string,
  handler: (command: TableCommand) => void
): () => void {
  function listener(event: Event) {
    const customEvent = event as CustomEvent<TableCommand>;
    const command = customEvent.detail;

    if (!command || command.blockId !== blockId) {
      return;
    }

    handler(command);
  }

  window.addEventListener(TABLE_COMMAND_EVENT, listener);

  return () => {
    window.removeEventListener(TABLE_COMMAND_EVENT, listener);
  };
}

export function emitTableSelectionChanged(
  selection: TableCellSelection | null
): void {
  window.dispatchEvent(
    new CustomEvent<TableCellSelection | null>(TABLE_SELECTION_EVENT, {
      detail: selection,
    })
  );
}

export function listenTableSelectionChanged(
  handler: (selection: TableCellSelection | null) => void
): () => void {
  function listener(event: Event) {
    const customEvent = event as CustomEvent<TableCellSelection | null>;
    handler(customEvent.detail ?? null);
  }

  window.addEventListener(TABLE_SELECTION_EVENT, listener);

  return () => {
    window.removeEventListener(TABLE_SELECTION_EVENT, listener);
  };
}
