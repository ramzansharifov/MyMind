import { useMemo, useState } from "react";
import type { FileStudyBlock } from "../../types/study";
import { formatBytes } from "../../utils/format";
import { DangerConfirmModal } from "../modals/DangerConfirmModal";

const MAX_FILE_SIZE = 8 * 1024 * 1024;

interface FileBlockProps {
  block: FileStudyBlock;
  editable: boolean;
  onChange: (block: FileStudyBlock) => void;
}

function isImage(mimeType: string): boolean {
  return mimeType.startsWith("image/");
}

function isPdf(mimeType: string, fileName: string): boolean {
  return mimeType === "application/pdf" || fileName.toLowerCase().endsWith(".pdf");
}

function isAudio(mimeType: string): boolean {
  return mimeType.startsWith("audio/");
}

function isVideo(mimeType: string): boolean {
  return mimeType.startsWith("video/");
}

function isTextLike(mimeType: string, fileName: string): boolean {
  const lowerName = fileName.toLowerCase();

  return (
    mimeType.startsWith("text/") ||
    mimeType.includes("json") ||
    lowerName.endsWith(".txt") ||
    lowerName.endsWith(".md") ||
    lowerName.endsWith(".json") ||
    lowerName.endsWith(".csv") ||
    lowerName.endsWith(".log") ||
    lowerName.endsWith(".ts") ||
    lowerName.endsWith(".tsx") ||
    lowerName.endsWith(".js") ||
    lowerName.endsWith(".jsx") ||
    lowerName.endsWith(".css") ||
    lowerName.endsWith(".html")
  );
}

function decodeDataUrlText(dataUrl: string): string {
  try {
    const commaIndex = dataUrl.indexOf(",");

    if (commaIndex === -1) return "";

    const meta = dataUrl.slice(0, commaIndex);
    const data = dataUrl.slice(commaIndex + 1);

    if (meta.includes(";base64")) {
      const binary = atob(data);
      const bytes = new Uint8Array(binary.length);

      for (let index = 0; index < binary.length; index += 1) {
        bytes[index] = binary.charCodeAt(index);
      }

      return new TextDecoder("utf-8").decode(bytes);
    }

    return decodeURIComponent(data);
  } catch {
    return "Не удалось прочитать текстовое содержимое файла.";
  }
}

export function FileBlock({ block, editable, onChange }: FileBlockProps) {
  const [clearOpen, setClearOpen] = useState(false);

  const textPreview = useMemo(() => {
    if (!block.dataUrl || !isTextLike(block.mimeType, block.fileName)) {
      return "";
    }

    return decodeDataUrlText(block.dataUrl);
  }, [block.dataUrl, block.mimeType, block.fileName]);

  function handleFile(file: File) {
    if (file.size > MAX_FILE_SIZE) {
      window.alert(`Файл слишком большой. Максимум: ${formatBytes(MAX_FILE_SIZE)}.`);
      return;
    }

    const reader = new FileReader();

    reader.onload = () => {
      onChange({
        ...block,
        fileName: file.name,
        mimeType: file.type || "application/octet-stream",
        size: file.size,
        dataUrl: String(reader.result ?? ""),
      });
    };

    reader.readAsDataURL(file);
  }

  function clearFile() {
    onChange({
      ...block,
      fileName: "",
      mimeType: "",
      size: 0,
      dataUrl: "",
    });

    setClearOpen(false);
  }

  const hasFile = Boolean(block.dataUrl && block.fileName);

  return (
    <div className="space-y-3">
      {editable && (
        <div className="border border-black bg-white p-3">
          <label className="block">
            <span className="mb-2 block text-sm font-bold">
              Загрузить файл
            </span>

            <input
              type="file"
              className="w-full border border-black bg-white px-3 py-2 text-sm"
              onChange={(event) => {
                const file = event.target.files?.[0];

                if (file) handleFile(file);

                event.currentTarget.value = "";
              }}
            />
          </label>

          <p className="mt-2 text-xs text-neutral-600">
            Максимальный размер: {formatBytes(MAX_FILE_SIZE)}. Файл сохраняется прямо в JSON как data URL.
          </p>
        </div>
      )}

      <label className="block">
        <span className="mb-2 block text-sm font-bold">
          Комментарий
        </span>

        <textarea
          value={block.note}
          disabled={!editable}
          onChange={(event) =>
            onChange({
              ...block,
              note: event.target.value,
            })
          }
          placeholder="Комментарий к файлу"
          rows={3}
          className="w-full border border-black bg-white px-3 py-2 outline-none disabled:bg-neutral-100"
        />
      </label>

      <div className="border border-black bg-white">
        <div className="border-b border-black bg-neutral-100 px-3 py-2 font-bold">
          Файл
        </div>

        {!hasFile && (
          <div className="p-4 text-sm text-neutral-600">
            Файл не выбран.
          </div>
        )}

        {hasFile && (
          <div className="p-4">
            <div className="grid gap-2 text-sm md:grid-cols-[140px_1fr]">
              <div className="font-bold">Название</div>
              <div className="break-all">{block.fileName}</div>

              <div className="font-bold">Тип</div>
              <div>{block.mimeType || "unknown"}</div>

              <div className="font-bold">Размер</div>
              <div>{formatBytes(block.size)}</div>
            </div>

            <div className="mt-4 flex flex-wrap gap-2">
              <a
                href={block.dataUrl}
                download={block.fileName}
                className="border border-black bg-black px-3 py-2 text-sm text-white"
              >
                Скачать
              </a>

              <a
                href={block.dataUrl}
                target="_blank"
                rel="noreferrer"
                className="border border-black bg-white px-3 py-2 text-sm text-black hover:bg-black hover:text-white"
              >
                Открыть
              </a>

              {editable && (
                <button
                  type="button"
                  onClick={() => setClearOpen(true)}
                  className="border border-black bg-white px-3 py-2 text-sm text-black hover:bg-black hover:text-white"
                >
                  Удалить файл
                </button>
              )}
            </div>
          </div>
        )}
      </div>

      {hasFile && (
        <div className="border border-black bg-white">
          <div className="border-b border-black bg-neutral-100 px-3 py-2 font-bold">
            Превью
          </div>

          <div className="p-4">
            {isImage(block.mimeType) && (
              <img
                src={block.dataUrl}
                alt={block.fileName}
                className="max-h-[520px] max-w-full border border-black object-contain"
              />
            )}

            {isPdf(block.mimeType, block.fileName) && (
              <iframe
                src={block.dataUrl}
                title={block.fileName}
                className="h-[520px] w-full border border-black"
              />
            )}

            {isAudio(block.mimeType) && (
              <audio controls src={block.dataUrl} className="w-full" />
            )}

            {isVideo(block.mimeType) && (
              <video controls src={block.dataUrl} className="max-h-[520px] w-full border border-black" />
            )}

            {textPreview && (
              <pre className="max-h-[520px] overflow-auto border border-black bg-neutral-100 p-3 text-sm">
                {textPreview}
              </pre>
            )}

            {!isImage(block.mimeType) &&
              !isPdf(block.mimeType, block.fileName) &&
              !isAudio(block.mimeType) &&
              !isVideo(block.mimeType) &&
              !textPreview && (
                <p className="text-sm text-neutral-600">
                  Для этого типа файла встроенное превью недоступно. Используй кнопки «Скачать» или «Открыть».
                </p>
              )}
          </div>
        </div>
      )}

      <DangerConfirmModal
        open={clearOpen}
        title="Удалить файл"
        message={`Файл "${block.fileName || "без названия"}" будет удалён из этого блока.`}
        requiredText="DELETE"
        confirmLabel="Удалить"
        onCancel={() => setClearOpen(false)}
        onConfirm={clearFile}
      />
    </div>
  );
}
