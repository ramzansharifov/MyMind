#root {
  width: 100vw;
  height: 100vh;
}

.tl-container {
  --color-background: #f8fafc;
}

.coordinate-plane-svg {
  display: block;
  user-select: none;
}

[data-slate-editor="true"] {
  outline: none;
}

[data-slate-editor="true"] p {
  margin: 0.75rem 0;
}

[data-slate-editor="true"] ul,
[data-slate-editor="true"] ol {
  margin: 0.75rem 0;
  padding-left: 1.5rem;
}

[data-slate-editor="true"] li {
  margin: 0.35rem 0;
}

[data-slate-editor="true"] table td,
[data-slate-editor="true"] table th {
  border: 1px solid #cbd5e1;
  padding: 0.75rem;
  vertical-align: top;
}

[data-slate-editor="true"] code {
  border-radius: 0.375rem;
  background: #f1f5f9;
  padding: 0.125rem 0.35rem;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  font-size: 0.9em;
}

[data-slate-editor="true"] mark {
  border-radius: 0.375rem;
  background: #fef08a;
  padding: 0.05rem 0.25rem;
}
