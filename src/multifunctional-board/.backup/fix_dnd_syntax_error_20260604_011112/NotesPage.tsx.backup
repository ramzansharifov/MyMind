import { useEffect, useMemo, useRef, useState } from 'react'
import type { ChangeEvent, DragEvent, ReactNode } from 'react'
import {
  BlockNoteSchema,
  defaultBlockSpecs,
  type PartialBlock,
} from '@blocknote/core'
import '@blocknote/core/fonts/inter.css'
import { createReactBlockSpec, useCreateBlockNote } from '@blocknote/react'
import { BlockNoteView } from '@blocknote/mantine'
import '@blocknote/mantine/style.css'
import * as katex from 'katex'
import 'katex/dist/katex.min.css'

const WORKSPACE_STORAGE_KEY = 'multifunctional-board-notes-workspace-v2'

type WorkspaceItemType = 'folder' | 'material'

type WorkspaceItem = {
  id: string
  type: WorkspaceItemType
  title: string
  parentId: string | null
  isOpen?: boolean
  order: number
  createdAt: string
  updatedAt: string
  document?: PartialBlock[]
}

type WorkspaceState = {
  items: WorkspaceItem[]
  selectedItemId: string | null
  activeMaterialId: string | null
}

type BlockColor =
  | 'default'
  | 'gray'
  | 'brown'
  | 'red'
  | 'orange'
  | 'yellow'
  | 'green'
  | 'blue'
  | 'purple'
  | 'pink'

type TextAlignment = 'left' | 'center' | 'right' | 'justify'

const colorOptions: BlockColor[] = [
  'default',
  'gray',
  'brown',
  'red',
  'orange',
  'yellow',
  'green',
  'blue',
  'purple',
  'pink',
]

const alignmentOptions: TextAlignment[] = ['left', 'center', 'right', 'justify']

function createId(prefix = 'item') {
  return `${prefix}-${Date.now()}-${Math.random().toString(36).slice(2)}`
}

function nowIso() {
  return new Date().toISOString()
}

function createMaterialDocument(title: string): PartialBlock[] {
  return [
    {
      type: 'heading',
      props: {
        level: 1,
      },
      content: title,
    },
    {
      type: 'paragraph',
      content:
        'Начни писать материал здесь. Используй / для меню BlockNote или верхнюю панель для быстрой вставки блоков.',
    },
  ]
}

const defaultMaterialDocument: PartialBlock[] = [
  {
    type: 'heading',
    props: {
      level: 1,
    },
    content: 'План доски',
  },
  {
    type: 'paragraph',
    content:
      'Это материал внутри VS Code-like панели. Каждый материал хранит собственный документ BlockNote.',
  },
  {
    type: 'codeBlock',
    props: {
      language: 'javascript',
    },
    content: 'console.log("Hello");',
  },
  {
    type: 'table',
    content: {
      type: 'tableContent',
      rows: [
        {
          cells: ['Заголовок 1', 'Заголовок 2', 'Заголовок 3'],
        },
        {
          cells: ['Введите текст...', 'Введите текст...', 'Введите текст...'],
        },
        {
          cells: ['Введите текст...', 'Введите текст...', 'Введите текст...'],
        },
      ],
    },
  } as any,
]

function createDefaultWorkspace(): WorkspaceState {
  const createdAt = nowIso()

  return {
    selectedItemId: 'material-board-plan',
    activeMaterialId: 'material-board-plan',
    items: [
      {
        id: 'folder-study',
        type: 'folder',
        title: 'Учёба',
        parentId: null,
        isOpen: true,
        order: 1,
        createdAt,
        updatedAt: createdAt,
      },
      {
        id: 'folder-projects',
        type: 'folder',
        title: 'Проекты',
        parentId: null,
        isOpen: true,
        order: 2,
        createdAt,
        updatedAt: createdAt,
      },
      {
        id: 'material-board-plan',
        type: 'material',
        title: 'План доски',
        parentId: 'folder-projects',
        order: 3,
        createdAt,
        updatedAt: createdAt,
        document: defaultMaterialDocument,
      },
      {
        id: 'material-test',
        type: 'material',
        title: 'Тестовый материал',
        parentId: 'folder-study',
        order: 4,
        createdAt,
        updatedAt: createdAt,
        document: createMaterialDocument('Тестовый материал'),
      },
    ],
  }
}

function loadWorkspace(): WorkspaceState {
  const saved = localStorage.getItem(WORKSPACE_STORAGE_KEY)

  if (!saved) return createDefaultWorkspace()

  try {
    const parsed = JSON.parse(saved) as WorkspaceState

    if (!Array.isArray(parsed.items)) {
      return createDefaultWorkspace()
    }

    const activeStillExists = parsed.items.some(
      (item) => item.id === parsed.activeMaterialId && item.type === 'material'
    )

    const firstMaterial = parsed.items.find((item) => item.type === 'material')

    return {
      items: parsed.items,
      selectedItemId:
        parsed.selectedItemId ?? parsed.activeMaterialId ?? firstMaterial?.id ?? null,
      activeMaterialId: activeStillExists
        ? parsed.activeMaterialId
        : firstMaterial?.id ?? null,
    }
  } catch {
    return createDefaultWorkspace()
  }
}

function getInlineText(content: unknown): string {
  if (typeof content === 'string') return content

  if (!Array.isArray(content)) return ''

  return content
    .map((item: any) => {
      if (typeof item === 'string') return item
      if (item?.type === 'text') return item.text ?? ''
      if (item?.type === 'link' && Array.isArray(item.content)) {
        return getInlineText(item.content)
      }

      return ''
    })
    .join('')
}

function LatexPreview({ formula }: { formula: string }) {
  const html = useMemo(() => {
    const source = formula.trim() || '\\text{Empty formula}'

    try {
      return katex.renderToString(source, {
        throwOnError: false,
        displayMode: true,
        output: 'html',
      })
    } catch {
      return katex.renderToString('\\text{Invalid LaTeX}', {
        throwOnError: false,
        displayMode: true,
        output: 'html',
      })
    }
  }, [formula])

  return (
    <div
      className="overflow-x-auto rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-center text-slate-950"
      dangerouslySetInnerHTML={{ __html: html }}
    />
  )
}

const LatexBlock = createReactBlockSpec(
  {
    type: 'latexBlock',
    propSchema: {
      backgroundColor: {
        default: 'default',
      },
      textColor: {
        default: 'default',
      },
      textAlignment: {
        default: 'left',
        values: ['left', 'center', 'right', 'justify'],
      },
    },
    content: 'inline',
  },
  {
    render: ({ block, contentRef }) => {
      const formula = getInlineText(block.content)

      return (
        <div className="bn-custom-cell bn-latex-cell">
          <div className="bn-custom-cell-header" contentEditable={false}>
            LaTeX
          </div>

          <div
            ref={contentRef}
            className="bn-latex-input"
            data-placeholder="Введите LaTeX, например: \frac{a}{b} + \sqrt{x}"
          />

          <LatexPreview formula={formula} />
        </div>
      )
    },
  }
)

