{
  "appId": "com.mymind.desktop",
  "productName": "MyMind",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "build/**/*",
    "package.json"
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": ["nsis"],
    "artifactName": "MyMind-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
